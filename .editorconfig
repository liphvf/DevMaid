root = true

# =============================================================================
# .editorconfig — Regras completas para projetos C# .NET
# Referência: https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/
#             https://learn.microsoft.com/dotnet/fundamentals/code-analysis/quality-rules/
# =============================================================================

# Níveis de severidade dos analyzers (.editorconfig)
#
# none        → desativa a regra (não aparece, não aplica no format)
# silent      → invisível na IDE (só refactoring), não aplica no format
# suggestion  → sugestão leve na IDE, aplica com `dotnet format --severity info`
# warning     → aviso visível, aplica no `dotnet format` padrão
# error       → erro de build, sempre aplicado pelo format
#
# Dica:
# - use 'error'   para erros de build (sempre aplicado pelo format)
# - use 'warning' para regras aplicadas automaticamente pelo format padrão
# - use 'suggestion' para estilo opcional (aplica com dotnet format --severity info)
# - use 'silent' para regras manuais (invisível na IDE, não aplica no format)
# - use 'none'   para desativar completamente

# -----------------------------------------------------------------------------
# Configurações universais (todos os arquivos)
# -----------------------------------------------------------------------------
[*]
# Estilo de indentação.
# Valores possíveis:
#   space → usa espaços (recomendado para C#)
#   tab   → usa caractere de tabulação
indent_style = space
# Garante que o arquivo termine com uma linha em branco
insert_final_newline = true
# Remove espaços em branco ao final das linhas
trim_trailing_whitespace = true
# Codificação padrão
charset = utf-8

# -----------------------------------------------------------------------------
# Arquivos XML / Projeto / Config
# -----------------------------------------------------------------------------
[*.xml]
indent_size = 2

[*.{csproj,fsproj,vbproj,proj,slnx}]
indent_size = 2

[*.{props,targets,config,nuspec}]
indent_size = 2

[*.json]
indent_size = 2

[*.{yml,yaml}]
indent_size = 2

# =============================================================================
# C# — Configurações principais
# =============================================================================
[*.cs]

#### Core EditorConfig Options ####

# Indentação de 4 espaços para C#
indent_size = 4
tab_width = 4

# =============================================================================
# .NET Coding Conventions (C# e VB)
# =============================================================================
[*.{cs,vb}]

# -----------------------------------------------------------------------------
# Organização de usings (IDE0055 / formatting)
# -----------------------------------------------------------------------------

# Descrição: Separa grupos de diretivas using com linha em branco entre os grupos
# Valores possíveis:
#   true  → insere linha em branco entre grupos de using
#            using System;
#
#            using MyApp;
#   false → sem separação entre grupos
#            using System;
#            using MyApp;
dotnet_separate_import_directive_groups = false

# Descrição: Ordena diretivas System.* antes das demais
# Valores possíveis:
#   true  → System.* vem antes de outros usings
#            using System;
#            using System.Collections.Generic;
#            using MyLib;
#   false → não força ordem especial para System.*
dotnet_sort_system_directives_first = true

# IDE0073: Cabeçalho de arquivo. Valores possíveis:
#   unset                              → desativa completamente
#   Copyright (c) MyCompany. All...   → qualquer texto literal (pode usar {fileName})
# Exemplo ativo:
#   file_header_template = Copyright (c) {year} MyCompany. Licensed under MIT.
file_header_template = unset

# -----------------------------------------------------------------------------
# IDE0003 / IDE0009 — Qualificação com this. e Me.
# -----------------------------------------------------------------------------

# Descrição: Qualificação this. em eventos
# Valores possíveis:
#   true  → exige this. ao referenciar eventos: this.MyEvent += handler;
#   false → omite this.: MyEvent += handler;
dotnet_style_qualification_for_event = false:suggestion

# Descrição: Qualificação this. em campos
# Valores possíveis:
#   true  → exige this. ao referenciar campos: this._name = value;
#   false → omite this.: _name = value;
dotnet_style_qualification_for_field = false:suggestion

# Descrição: Qualificação this. em métodos
# Valores possíveis:
#   true  → exige this. ao chamar métodos: this.Run();
#   false → omite this.: Run();
dotnet_style_qualification_for_method = false:suggestion

# Descrição: Qualificação this. em propriedades
# Valores possíveis:
#   true  → exige this. ao acessar propriedades: this.Name = value;
#   false → omite this.: Name = value;
dotnet_style_qualification_for_property = false:suggestion

# -----------------------------------------------------------------------------
# IDE0049 — Palavras-chave vs nomes de tipos BCL
# -----------------------------------------------------------------------------

# Descrição: Prefere palavras-chave de linguagem (int, string) em vez de nomes BCL (Int32, String) para variáveis e parâmetros
# Valores possíveis:
#   true  → usa palavra-chave da linguagem
#            int x = 0;
#   false → usa nome do tipo BCL
#            Int32 x = 0;
dotnet_style_predefined_type_for_locals_parameters_members = true:suggestion

# Descrição: Prefere palavras-chave de linguagem para acesso a membros estáticos de tipos
# Valores possíveis:
#   true  → usa palavra-chave da linguagem
#            int.MaxValue
#   false → usa nome do tipo BCL
#            Int32.MaxValue
dotnet_style_predefined_type_for_member_access = true:suggestion

# -----------------------------------------------------------------------------
# IDE0047 / IDE0048 — Parênteses
# Operadores aritméticos: *, /, %, +, -, <<, >>, &, ^, |
# Valores possíveis:
#   always_for_clarity  → mantém parênteses mesmo quando desnecessários (mais legível)
#                         true: var x = (a * b) + c;
#   never_if_unnecessary → remove parênteses quando a precedência é óbvia
#                          true: var x = a * b + c;
dotnet_style_parentheses_in_arithmetic_binary_operators = always_for_clarity:suggestion

# Operadores relacionais: >, <, <=, >=, is, as, ==, !=
# Valores possíveis:
#   always_for_clarity  → var r = (a < b) == (c > d);
#   never_if_unnecessary → var r = a < b == c > d;
dotnet_style_parentheses_in_relational_binary_operators = always_for_clarity:suggestion

# Outros operadores binários: &&, ||, ??
# Valores possíveis:
#   always_for_clarity  → var r = a || (b && c);
#   never_if_unnecessary → var r = a || b && c;
dotnet_style_parentheses_in_other_binary_operators = always_for_clarity:suggestion

# Demais operadores (member access, cast, ternary, etc.)
# Valores possíveis:
#   always_for_clarity  → var v = (a.b).Length;
#   never_if_unnecessary → var v = a.b.Length;
dotnet_style_parentheses_in_other_operators = never_if_unnecessary:warning

# -----------------------------------------------------------------------------
# IDE0040 — Modificadores de acessibilidade
# Valores possíveis:
#   always               → exige modificador em TODOS os membros
#                          public class Foo { private int _x; }
#   for_non_interface_members → exige em todos EXCETO membros de interface
#                          (interface members são public por padrão)
#   never                → nunca exige modificador explícito
#   omit_if_default      → omite quando o modificador é o padrão para o contexto
#                          (ex: private é padrão em class, então pode omitir)
dotnet_style_require_accessibility_modifiers = for_non_interface_members:warning

# -----------------------------------------------------------------------------
# Preferências de nível de expressão
# -----------------------------------------------------------------------------

# Descrição: Prefere operador de coalescência nula ?? em vez de verificações ternárias de nulo
# Valores possíveis:
#   true  → usa operador ??
#            var x = a ?? b;
#   false → usa expressão ternária
#            var x = a != null ? a : b;
dotnet_style_coalesce_expression = true:suggestion

# Descrição: Prefere collection initializers ao inicializar coleções
# Valores possíveis:
#   true  → usa inicializador de coleção
#            var l = new List<int> { 1, 2, 3 };
#   false → usa chamadas Add separadas
#            var l = new List<int>(); l.Add(1);
dotnet_style_collection_initializer = true:suggestion

# Descrição: Prefere nomes explícitos de tupla em vez de Item1/Item2
# Valores possíveis:
#   true  → usa nome explícito do campo da tupla
#            tuple.Name
#   false → usa acesso por índice
#            tuple.Item1
dotnet_style_explicit_tuple_names = true:warning

# Descrição: Namespace deve corresponder à estrutura de pastas do projeto
# Valores possíveis:
#   true  → exige que o namespace reflita o caminho de pasta
#            Em pasta Foo/Bar: namespace MyApp.Foo.Bar;
#   false → não verifica correspondência
dotnet_style_namespace_match_folder = true:warning

# Descrição: Prefere propagação de nulo (?.) em vez de verificação explícita
# Valores possíveis:
#   true  → usa operador ?.
#            var x = obj?.Property;
#   false → usa verificação ternária explícita
#            var x = obj != null ? obj.Property : null;
dotnet_style_null_propagation = true:warning

# Descrição: Prefere object initializers ao inicializar objetos
# Valores possíveis:
#   true  → usa inicializador de objeto
#            var p = new Person { Name = "Ana" };
#   false → usa atribuições de propriedade separadas
#            var p = new Person(); p.Name = "Ana";
dotnet_style_object_initializer = true:suggestion

# Posição do operador ao quebrar linha em expressão multiline.
# Valores possíveis:
#   beginning_of_line → operador vai para o início da próxima linha
#     var x = a
#         + b
#         + c;
#   end_of_line → operador fica no final da linha corrente
#     var x = a +
#         b +
#         c;
dotnet_style_operator_placement_when_wrapping = beginning_of_line

# Descrição: Prefere propriedades automáticas quando não há lógica extra no accessor
# Valores possíveis:
#   true  → usa propriedade automática
#            public int Age { get; set; }
#   false → mantém campo de apoio explícito
#            private int _age; public int Age { get { return _age; } set { _age = value; } }
dotnet_style_prefer_auto_properties = true:suggestion

# IDE0028/IDE0300-IDE0306: Prefere expressões de coleção [] (C# 12+)
# Valores possíveis:
#   true | when_types_exactly_match → aplica somente quando o tipo é exatamente o mesmo
#     List<int> x = new List<int>() { 1, 2 };  →  List<int> x = [1, 2];
#   when_types_loosely_match → aplica mesmo quando tipos são compatíveis/assignables
#     IEnumerable<int> x = new List<int>() { 1, 2 };  →  IEnumerable<int> x = [1, 2];
#     Suporta: IEnumerable<T>, ICollection<T>, IList<T>, IReadOnlyCollection<T>, IReadOnlyList<T>
#   false | never → desativa completamente
dotnet_style_prefer_collection_expression = when_types_loosely_match:suggestion

# Descrição: Prefere compound assignment (+=, -=, ??=, etc.)
# Valores possíveis:
#   true  → usa operador de atribuição composta (IDE0054 para +=/-=, IDE0074 para ??=)
#            x += 1;
#   false → usa atribuição com operação separada
#            x = x + 1;
dotnet_style_prefer_compound_assignment = true:suggestion

# Descrição: Prefere expressão condicional em atribuição
# Valores possíveis:
#   true  → usa operador ternário
#            var x = cond ? a : b;
#   false → usa if/else
#            if (cond) x = a; else x = b;
dotnet_style_prefer_conditional_expression_over_assignment = true:suggestion

# Descrição: Prefere expressão condicional em return
# Valores possíveis:
#   true  → usa operador ternário no return
#            return cond ? a : b;
#   false → usa if/else com return
#            if (cond) return a; else return b;
dotnet_style_prefer_conditional_expression_over_return = true:suggestion

# IDE0220: Prefere cast explícito no foreach quando o compilador adicionaria um cast oculto.
# Valores possíveis:
#   always             → exige cast explícito em todos os casos
#     foreach (string s in list.Cast<string>()) { }
#   when_strongly_typed → exige cast apenas em generic collections (strongly typeds)
#     — não aplica para legacy collections como ArrayList
dotnet_style_prefer_foreach_explicit_cast_in_source = when_strongly_typed:suggestion

# Descrição: Prefere nomes inferidos em anonymous types quando o nome pode ser omitido
# Valores possíveis:
#   true  → usa nome inferido
#            new { Name }
#   false → usa nome explícito
#            new { Name = Name }
dotnet_style_prefer_inferred_anonymous_type_member_names = true:suggestion

# Descrição: Prefere nomes inferidos em tuplas quando o nome pode ser omitido
# Valores possíveis:
#   true  → usa nome inferido
#            (Name, Age)
#   false → usa nome explícito
#            (Name: Name, Age: Age)
dotnet_style_prefer_inferred_tuple_names = true:suggestion

# Descrição: Prefere null check com is null em vez de ReferenceEquals
# Valores possíveis:
#   true  → usa pattern matching
#            obj is null
#   false → usa chamada estática
#            object.ReferenceEquals(obj, null)
dotnet_style_prefer_is_null_check_over_reference_equality_method = true:suggestion

# Descrição: Simplifica expressões booleanas condicionais desnecessariamente complexas
# Valores possíveis:
#   true  → simplifica a expressão
#            return a && b;
#   false → mantém a expressão original
#            return a && b ? true : false;
dotnet_style_prefer_simplified_boolean_expressions = true:warning

# Descrição: Simplifica interpolação de strings removendo chamadas ToString() redundantes
# Valores possíveis:
#   true  → simplifica a interpolação
#            $"{x}"
#   false → mantém a chamada explícita
#            $"{x.ToString()}"
dotnet_style_prefer_simplified_interpolation = true:warning

# -----------------------------------------------------------------------------
# IDE0044 — Preferências de campo
# -----------------------------------------------------------------------------

# Descrição: Adiciona readonly em campos que não são reatribuídos após o construtor
# Valores possíveis:
#   true  → marca o campo como readonly
#            private readonly int _x;
#   false → não exige readonly
dotnet_style_readonly_field = true:warning

# -----------------------------------------------------------------------------
# IDE0060 — Preferências de parâmetro
# -----------------------------------------------------------------------------

# IDE0060 — Parâmetros não utilizados
# Valores possíveis:
#   all        → reporta parâmetros não usados em métodos de qualquer acessibilidade
#                (public, internal, private, protected)
#   non_public → reporta apenas em métodos não-públicos (internal, private, protected)
#                — evita falsos positivos em APIs públicas/contratos de interface
dotnet_code_quality_unused_parameters = all:suggestion

# -----------------------------------------------------------------------------
# IDE0079 — Supressões desnecessárias
# -----------------------------------------------------------------------------

# IDE0079 — Supressões desnecessárias
# Valores possíveis:
#   none              → não exclui nada (analisa todas as supressões)
#   all               → exclui/ignora todas as supressões (desativa a regra inteiramente)
#   category:Style    → ignora supressões da categoria "Style"
#   CA1822,IDE0051    → lista de IDs separados por vírgula a ignorar
dotnet_remove_unnecessary_suppression_exclusions = none

# =============================================================================
# C# Coding Conventions
# =============================================================================
[*.cs]

# -----------------------------------------------------------------------------
# IDE0007 / IDE0008 — Preferências de var
# -----------------------------------------------------------------------------

# Descrição: Prefere tipo explícito em vez de var para tipos primitivos (built-in)
# Valores possíveis:
#   true  → usa var para built-in types
#            var x = 0;
#   false → usa tipo explícito
#            int x = 0;
csharp_style_var_for_built_in_types = true:warning

# Descrição: Prefere tipo explícito quando o tipo já é aparente pela expressão
# Valores possíveis:
#   true  → usa var quando o tipo é aparente
#            var c = new Customer();
#   false → usa tipo explícito mesmo quando aparente
#            Customer c = new Customer();
csharp_style_var_when_type_is_apparent = true:warning

# Descrição: Prefere tipo explícito em demais casos onde o tipo não é aparente
# Valores possíveis:
#   true  → usa var em qualquer situação
#            var e = GetItems();
#   false → usa tipo explícito
#            IEnumerable<int> e = GetItems();
csharp_style_var_elsewhere = true:warning

# -----------------------------------------------------------------------------
# IDE0021-IDE0027 / IDE0053 / IDE0061 — Membros com expression body
# -----------------------------------------------------------------------------

# IDE0027 — accessors de propriedade com expression body.
# Valores possíveis:
#   true              → prefere sempre:  get => _name;
#   false             → prefere sempre:  get { return _name; }
#   when_on_single_line → usa expressão apenas quando o corpo cabe em uma única linha
csharp_style_expression_bodied_accessors = false:silent

# IDE0021 — Construtores com expression body.
# Valores possíveis:
#   true              → prefere:  public Foo() => _x = 1;
#   false             → prefere:  public Foo() { _x = 1; }
#   when_on_single_line → usa expressão apenas se o construtor cabe em uma linha
csharp_style_expression_bodied_constructors = false:silent

# IDE0026 — indexers com expression body.
# Valores possíveis:
#   true              → prefere:  public int this[int i] => _items[i];
#   false             → prefere bloco com return
#   when_on_single_line → usa expressão apenas se cabe em uma linha
csharp_style_expression_bodied_indexers = true:silent

# IDE0053 — Lambdas com expression body.
# Valores possíveis:
#   true              → prefere:  Func<int,int> f = x => x + 1;
#   false             → prefere:  Func<int,int> f = x => { return x + 1; };
#   when_on_single_line → usa expressão apenas se cabe em uma linha
csharp_style_expression_bodied_lambdas = true:suggestion

# IDE0061 — Funções locais com expression body.
# Valores possíveis:
#   true              → prefere:  int Local() => 1;
#   false             → prefere:  int Local() { return 1; }
#   when_on_single_line → usa expressão apenas se cabe em uma linha
csharp_style_expression_bodied_local_functions = true:silent

# IDE0022 — Métodos com expression body.
# Valores possíveis:
#   true              → prefere:  void Run() => DoWork();
#   false             → prefere:  void Run() { DoWork(); }
#   when_on_single_line → usa expressão apenas se cabe em uma linha
csharp_style_expression_bodied_methods = false:silent

# IDE0023/IDE0024 — Operadores com expression body.
# Valores possíveis:
#   true              → prefere:  public static Foo operator +(Foo a, Foo b) => new(a.X + b.X);
#   false             → prefere bloco com return
#   when_on_single_line → usa expressão apenas se cabe em uma linha
csharp_style_expression_bodied_operators = false:silent

# IDE0025 — Propriedades com expression body.
# Valores possíveis:
#   true              → prefere:  public string Name => _name;
#   false             → prefere:  public string Name { get { return _name; } }
#   when_on_single_line → usa expressão apenas se cabe em uma linha
csharp_style_expression_bodied_properties = true:silent

# -----------------------------------------------------------------------------
# IDE0019 / IDE0020 / IDE0038 / IDE0078 / IDE0083 / IDE0150 — Pattern matching
# -----------------------------------------------------------------------------

# Descrição: Prefere pattern matching com is em vez de as + null check
# Valores possíveis:
#   true  → usa pattern matching
#            if (obj is string s) { }
#   false → usa as com null check explícito
#            var s = obj as string; if (s != null) { }
csharp_style_pattern_matching_over_as_with_null_check = true:warning

# Descrição: Prefere pattern matching com is em vez de is + cast explícito
# Valores possíveis:
#   true  → usa pattern matching
#            if (obj is int i) { }
#   false → usa is com cast separado
#            if (obj is int) { var i = (int)obj; }
csharp_style_pattern_matching_over_is_with_cast_check = true:warning

# Descrição: Simplifica extended property pattern aninhado
# Valores possíveis:
#   true  → usa property pattern compacto
#            if (a is { B.C: 1 }) { }
#   false → usa property pattern aninhado
#            if (a is { B: { C: 1 } }) { }
csharp_style_prefer_extended_property_pattern = true:warning

# Descrição: Prefere o operador not em patterns em vez de negação com !
# Valores possíveis:
#   true  → usa operador not
#            if (obj is not null) { }
#   false → usa negação com !
#            if (!(obj is null)) { }
csharp_style_prefer_not_pattern = true:warning

# Descrição: Prefere pattern matching quando há alternativa equivalente
# Valores possíveis:
#   true  → usa pattern matching
#            if (obj is int or string) { }
#   false → não força uso de pattern matching
csharp_style_prefer_pattern_matching = true:suggestion

# Descrição: Prefere switch expression em vez de switch statement
# Valores possíveis:
#   true  → usa switch expression
#            var x = y switch { 1 => "a", _ => "b" };
#   false → usa switch statement tradicional
csharp_style_prefer_switch_expression = true:warning

# Descrição: Prefere null check com is null em vez de verificação de tipo negada
# Valores possíveis:
#   true  → usa null check direto
#            if (obj is null) { }
#   false → usa negação de type check
#            if (obj is not MyType) { }
csharp_style_prefer_null_check_over_type_check = true:suggestion

# -----------------------------------------------------------------------------
# IDE1005 — Null-checking em delegates
# -----------------------------------------------------------------------------

# Descrição: Usa chamada condicional de delegate (?.) em vez de null check explícito
# Valores possíveis:
#   true  → usa chamada condicional
#            handler?.Invoke(this, args);
#   false → usa null check explícito
#            if (handler != null) handler(this, args);
csharp_style_conditional_delegate_call = true:warning

# -----------------------------------------------------------------------------
# Modificadores
# -----------------------------------------------------------------------------

# Descrição: Prefere funções anônimas static quando não capturam estado externo
# Valores possíveis:
#   true  → marca a função anônima como static
#            Action f = static () => Console.WriteLine("hello");
#   false → não exige static em funções anônimas
csharp_prefer_static_anonymous_function = true:warning

# Descrição: Prefere funções locais static quando não capturam estado externo
# Valores possíveis:
#   true  → marca a função local como static
#            static void Local() { }
#   false → não exige static em funções locais
csharp_prefer_static_local_function = true:warning

# IDE0036: Ordem preferida dos modificadores (lista separada por vírgula).
# A ordem dos tokens define a ordenação exigida na declaração de membros.
# Modificadores disponíveis:
#   public, private, protected, internal, file
#   new, abstract, virtual, sealed, override, extern
#   static, const, readonly, volatile, unsafe, required, async
# Exemplo: public static readonly string Name = ...;
csharp_preferred_modifier_order = public,private,protected,internal,file,const,static,extern,new,virtual,abstract,sealed,override,readonly,unsafe,required,volatile,async:suggestion

# Descrição: Structs podem ser marcadas como readonly quando não modificam estado
# Valores possíveis:
#   true  → marca a struct como readonly quando possível
#            readonly struct Point { public int X { get; init; } }
#   false → não exige readonly em structs
csharp_style_prefer_readonly_struct = true:warning

# Descrição: Membros de struct podem ser readonly quando não modificam estado
# Valores possíveis:
#   true  → marca o membro como readonly quando possível
#            public readonly int GetX() => X;
#   false → não exige readonly em membros de struct
csharp_style_prefer_readonly_struct_member = true:warning

# -----------------------------------------------------------------------------
# Preferências de bloco de código
# -----------------------------------------------------------------------------

# IDE0011 — Chaves em control flow blocks.
# Valores possíveis:
#   true         → exige braces mesmo em single-line blocks
#                  if (x) { DoIt(); }
#   false        → prefere sem braces quando possível
#                  if (x) DoIt();
#   when_multiline → exige braces apenas quando o bloco tem múltiplas linhas
#                    if (x) DoIt();           // sem braces (uma linha)
#                    else { A(); B(); }       // com braces (múltiplas linhas)
csharp_prefer_braces = true:none

# Descrição: Usa declaração using simplificada (sem bloco explícito)
# Valores possíveis:
#   true  → usa using declaration (sem bloco)
#            using var fs = File.Open(...);
#   false → usa using statement com bloco
#            using (var fs = File.Open(...)) { }
csharp_prefer_simple_using_statement = true:suggestion

# IDE0160/IDE0161: Estilo de namespace declaration.
# Valores possíveis:
#   file_scoped  → namespace sem braces, ocupa o arquivo inteiro (C# 10+)
#                  namespace MyApp.Services;
#                  class Foo { }
#   block_scoped → namespace com braces (estilo tradicional)
#                  namespace MyApp.Services
#                  {
#                      class Foo { }
#                  }
csharp_style_namespace_declarations = file_scoped:warning

# Descrição: Remove lambda desnecessária e usa method group quando possível
# Valores possíveis:
#   true  → usa method group diretamente
#            list.ForEach(Console.WriteLine);
#   false → mantém a lambda explícita
#            list.ForEach(x => Console.WriteLine(x));
csharp_style_prefer_method_group_conversion = true:suggestion

# Descrição: Prefere construtores primários (C# 12+)
# Valores possíveis:
#   true  → usa construtor primário
#            class Point(int x, int y);
#   false → usa construtor tradicional com corpo
csharp_style_prefer_primary_constructors = true:suggestion

# Descrição: Prefere top-level statements em vez de classe Program/Main explícita (C# 9+)
# Valores possíveis:
#   true  → usa top-level statements (sem class Program/Main explícitos)
#   false → usa estrutura tradicional com classe e método Main
csharp_style_prefer_top_level_statements = true:silent

# -----------------------------------------------------------------------------
# Preferências de nível de expressão (C#)
# -----------------------------------------------------------------------------

# Descrição: Simplifica expressão default removendo o tipo explícito quando pode ser inferido
# Valores possíveis:
#   true  → usa default sem tipo
#            default
#   false → usa default com tipo explícito
#            default(int)
csharp_prefer_simple_default_expression = true:warning

# Descrição: Prefers deconstruction of variable declarations quando possível
# Valores possíveis:
#   true  → usa deconstruction
#            var (x, y) = GetPoint();
#   false → usa acesso a membros separado
#            var p = GetPoint(); var x = p.X;
csharp_style_deconstructed_variable_declaration = true:suggestion

# Descrição: Cria objeto implicitamente (new()) quando o tipo é aparente pelo contexto (C# 9+)
# Valores possíveis:
#   true  → usa target-typed new
#            Customer c = new();
#   false → usa construtor com tipo explícito
#            Customer c = new Customer();
csharp_style_implicit_object_creation_when_type_is_apparent = true:suggestion

# Descrição: Declara variável inline em parâmetro out
# Valores possíveis:
#   true  → declara inline no out
#            int.TryParse(s, out int n)
#   false → declara separado antes da chamada
#            int n; int.TryParse(s, out n);
csharp_style_inlined_variable_declaration = true:suggestion

# Descrição: Usa index operator (^) para acesso a partir do final de coleção
# Valores possíveis:
#   true  → usa operador ^
#            var last = list[^1];
#   false → usa cálculo manual de índice
#            var last = list[list.Count - 1];
csharp_style_prefer_index_operator = true:suggestion

# Descrição: Prefere função local a função anônima (Func/Action) quando possível
# Valores possíveis:
#   true  → usa função local
#            int Local() => 1;
#   false → usa função anônima
#            Func<int> f = () => 1;
csharp_style_prefer_local_over_anonymous_function = true:silent

# Descrição: Usa range operator (..) para fatiar sequências
# Valores possíveis:
#   true  → usa operador ..
#            var sub = arr[1..4];
#   false → usa métodos de extensão
#            var sub = arr.Skip(1).Take(3);
csharp_style_prefer_range_operator = true:suggestion

# Descrição: Prefere tuple swap para trocar valores de variáveis
# Valores possíveis:
#   true  → usa tuple para swap
#            (a, b) = (b, a);
#   false → usa variável temporária
#            var tmp = a; a = b; b = tmp;
csharp_style_prefer_tuple_swap = true:warning

# Descrição: Prefere literal de string UTF-8 (C# 11+)
# Valores possíveis:
#   true  → usa literal u8
#            ReadOnlySpan<byte> b = "hello"u8;
#   false → usa outra forma de representar bytes
csharp_style_prefer_utf8_string_literals = true:warning

# Descrição: Usa throw expression em vez de if+throw em inicializações e atribuições
# Valores possíveis:
#   true  → usa throw expression
#            _name = name ?? throw new ArgumentNullException(nameof(name));
#   false → usa if+throw block separado
csharp_style_throw_expression = true:suggestion

# IDE0059 — Unused variable in assignment.
# Valores possíveis:
#   discard_variable    → usa _ para descartar (discard) explicitamente
#                         _ = GetValue();
#   unused_local_variable → atribui a variável local nunca lida
#                           var unused = GetValue();
csharp_style_unused_value_assignment_preference = discard_variable:silent

# IDE0058 — Unused expression value.
# Valores possíveis:
#   discard_variable    → usa _ para usar discard para o resultado
#                         _ = list.Remove(item);
#   unused_local_variable → atribui o resultado a variável local nunca lida
#                           var unused = list.Remove(item);
csharp_style_unused_value_expression_statement_preference = discard_variable:silent

# Descrição: Prefere System.Threading.Lock em vez de object para locks (C# 13+)
# Valores possíveis:
#   true  → usa o tipo Lock dedicado
#            private readonly Lock _lock = new();
#   false → usa object como lock
#            private readonly object _lock = new();
csharp_prefer_system_threading_lock = true:warning

# Descrição: Prefere unbound generic type em nameof (sem argumentos de tipo)
# Valores possíveis:
#   true  → usa unbound generic
#            nameof(List<>)
#   false → especifica tipo concreto
#            nameof(List<int>)
csharp_style_prefer_unbound_generic_type_in_nameof = true:suggestion

# Descrição: Prefere lambda implicitly typed quando o tipo pode ser inferido pelo compilador (C# 10+)
# Valores possíveis:
#   true  → usa lambda com tipo implícito e var
#            var f = (int x) => x + 1;
#   false → usa tipo de delegate explícito
csharp_style_prefer_implicitly_typed_lambda_expression = true:warning

# Descrição: Simplifica accessors de propriedade para expression body quando possível
# Valores possíveis:
#   true  → usa expression body no accessor
#            get => _value;
#   false → usa bloco com return
#            get { return _value; }
csharp_style_prefer_simple_property_accessors = true:suggestion

# -----------------------------------------------------------------------------
# IDE0065 — Posicionamento de diretiva using
# -----------------------------------------------------------------------------

# IDE0065 — Posicionamento de diretiva using.
# Valores possíveis:
#   outside_namespace → using fica FORA do namespace (padrão histórico C#)
#                       using System;
#                       namespace Foo { class Bar { } }
#   inside_namespace  → using fica DENTRO do namespace (evita poluir escopo global)
#                       namespace Foo
#                       {
#                           using System;
#                           class Bar { }
#                       }
csharp_using_directive_placement = outside_namespace:warning

# =============================================================================
# C# Formatting Rules (IDE0055)
# =============================================================================

# -----------------------------------------------------------------------------
# Preferências de nova linha
# -----------------------------------------------------------------------------

# Descrição: Posiciona a cláusula catch em nova linha após o bloco try
# Valores possíveis:
#   true  → catch em nova linha
#            try { } catch { }
#   false → catch na mesma linha que a chave de fechamento do try
csharp_new_line_before_catch = true

# Descrição: Posiciona a cláusula else em nova linha após o bloco if
# Valores possíveis:
#   true  → else em nova linha
#            if (...) { } else { }
#   false → else na mesma linha que a chave de fechamento do if
csharp_new_line_before_else = true

# Descrição: Posiciona a cláusula finally em nova linha após o bloco catch
# Valores possíveis:
#   true  → finally em nova linha
#            catch { } finally { }
#   false → finally na mesma linha que a chave de fechamento do catch
csharp_new_line_before_finally = true

# Descrição: Membros de anonymous types ficam em linhas separadas
# Valores possíveis:
#   true  → cada membro em nova linha
#            var z = new { A = 1, B = 2 }
#   false → todos os membros na mesma linha
csharp_new_line_before_members_in_anonymous_types = true

# Descrição: Membros de object initializers ficam em linhas separadas
# Valores possíveis:
#   true  → cada membro em nova linha
#            var p = new Person { Name = "Ana", Age = 30 }
#   false → todos os membros na mesma linha
csharp_new_line_before_members_in_object_initializers = true

# csharp_new_line_before_open_brace — Abre chave { em nova linha.
# Valores possíveis:
#   all     → nova linha para TODOS os elementos (estilo Allman)
#             void Foo()
#             {
#                 if (x)
#                 {
#                 }
#             }
#   none    → chave na mesma linha (estilo K&R)
#             void Foo() {
#                 if (x) {
#                 }
#             }
#   Lista separada por vírgula de elementos específicos:
#     accessors, anonymous_methods, anonymous_types, control_blocks,
#     events, indexers, lambdas, local_functions, methods,
#     object_collection_array_initializers, properties, types
#   Exemplo: methods, properties, types  (apenas nesses, resto na mesma linha)
csharp_new_line_before_open_brace = all

# Descrição: Cláusulas de query expression ficam em linhas separadas
# Valores possíveis:
#   true  → cada cláusula em nova linha
#            var q = from a in e where a > 0 select a;
#   false → cláusulas na mesma linha
csharp_new_line_between_query_expression_clauses = true

# -----------------------------------------------------------------------------
# Preferências de indentação
# -----------------------------------------------------------------------------

# Descrição: Indenta o conteúdo de blocos de código
# Valores possíveis:
#   true  → conteúdo do bloco é indentado
#            { Console.WriteLine(); }
#   false → conteúdo sem indentação adicional
csharp_indent_block_contents = true

# Descrição: Indenta as próprias chaves em vez de apenas o conteúdo
# Valores possíveis:
#   true  → as chaves são indentadas
#   false → chaves ficam no nível do elemento pai
#            void Foo() {
csharp_indent_braces = false

# Descrição: Indenta o conteúdo de case dentro de switch
# Valores possíveis:
#   true  → conteúdo de case é indentado
#            switch(x) { case 1: break; }
#   false → conteúdo de case no mesmo nível do case
csharp_indent_case_contents = true

# Descrição: Indenta o bloco dentro de case como bloco separado
# Valores possíveis:
#   true  → bloco dentro do case é indentado separadamente
#            case 0: { break; }
#   false → sem indentação extra para o bloco
csharp_indent_case_contents_when_block = true

# csharp_indent_labels — Indentação de labels (goto).
# Valores possíveis:
#   flush_left          → label na coluna 0 (margem esquerda absoluta)
#   one_less_than_current → label recuado um nível menos que o contexto atual
#   no_change           → label no mesmo nível do contexto atual
# Exemplo com one_less_than_current:
#   void Foo() {
#       if (x) goto myLabel;
#   myLabel:
#       throw new Exception();
#   }
csharp_indent_labels = one_less_than_current

# Descrição: Indenta os labels de case dentro do switch
# Valores possíveis:
#   true  → labels de case são indentados em relação ao switch
#            switch(x) { case 1: }
#   false → labels de case no mesmo nível do switch
csharp_indent_switch_labels = true

# -----------------------------------------------------------------------------
# Preferências de espaçamento
# -----------------------------------------------------------------------------

# Descrição: Espaço após operador de cast
# Valores possíveis:
#   true  → insere espaço após o cast
#            (int) x
#   false → sem espaço após o cast
#            (int)x
csharp_space_after_cast = false

# Descrição: Espaço após : na cláusula de herança de classe
# Valores possíveis:
#   true  → insere espaço após :
#            class Foo : IBar { }
#   false → sem espaço após :
csharp_space_after_colon_in_inheritance_clause = true

# Descrição: Espaço após vírgula em listas de argumentos e parâmetros
# Valores possíveis:
#   true  → insere espaço após ,
#            Foo(a, b, c)
#   false → sem espaço após ,
#            Foo(a,b,c)
csharp_space_after_comma = true

# Descrição: Espaço após ponto (.) em acesso a membros
# Valores possíveis:
#   true  → insere espaço após o ponto
#            obj. Method()
#   false → sem espaço após o ponto
#            obj.Method()
csharp_space_after_dot = false

# Descrição: Espaço após palavra-chave de controle de fluxo antes do parêntese
# Valores possíveis:
#   true  → insere espaço após a palavra-chave
#            if (x)
#   false → sem espaço
#            if(x)
csharp_space_after_keywords_in_control_flow_statements = true

# Descrição: Espaço após ponto e vírgula (;) no cabeçalho do for
# Valores possíveis:
#   true  → insere espaço após ;
#            for (int i = 0; i < 10; i++)
#   false → sem espaço após ;
csharp_space_after_semicolon_in_for_statement = true

# csharp_space_around_binary_operators — Espaços ao redor de operadores binários.
# Valores possíveis:
#   before_and_after → espaço antes E depois do operador (padrão recomendado)
#                      var x = a + b;
#   none             → sem espaços
#                      var x = a+b;
#   ignore           → preserva o espaçamento existente (não altera)
csharp_space_around_binary_operators = before_and_after

# Descrição: Espaço ao redor de declarações de variáveis
# Valores possíveis:
#   true  → insere espaço ao redor
#   false → sem espaço extra ao redor de declarações
csharp_space_around_declaration_statements = false

# Descrição: Espaço antes de : na cláusula de herança de classe
# Valores possíveis:
#   true  → insere espaço antes de :
#            class Foo : IBar { }
#   false → sem espaço antes de :
csharp_space_before_colon_in_inheritance_clause = true

# Descrição: Espaço antes de vírgula em listas de argumentos e parâmetros
# Valores possíveis:
#   true  → insere espaço antes de ,
#            Foo(a , b)
#   false → sem espaço antes de ,
#            Foo(a, b)
csharp_space_before_comma = false

# Descrição: Espaço antes de ponto (.) em acesso a membros
# Valores possíveis:
#   true  → insere espaço antes do ponto
#            obj .Method()
#   false → sem espaço antes do ponto
#            obj.Method()
csharp_space_before_dot = false

# Descrição: Espaço antes de colchete de abertura em acesso a array/indexer
# Valores possíveis:
#   true  → insere espaço antes de [
#            arr [0]
#   false → sem espaço antes de [
#            arr[0]
csharp_space_before_open_square_brackets = false

# Descrição: Espaço antes de ponto e vírgula (;) no cabeçalho do for
# Valores possíveis:
#   true  → insere espaço antes de ;
#   false → sem espaço antes de ;
#            for (int i = 0; i < 10; i++)
csharp_space_before_semicolon_in_for_statement = false

# Descrição: Espaço entre colchetes vazios [] em declaração de array
# Valores possíveis:
#   true  → insere espaço dentro
#            int[ ]
#   false → sem espaço
#            int[]
csharp_space_between_empty_square_brackets = false

# Descrição: Espaço dentro dos parênteses em chamada de método sem parâmetros
# Valores possíveis:
#   true  → insere espaço dentro
#            Foo( )
#   false → sem espaço
#            Foo()
csharp_space_between_method_call_empty_parameter_list_parentheses = false

# Descrição: Espaço entre o nome do método e o parêntese de abertura na chamada
# Valores possíveis:
#   true  → insere espaço
#            Foo ()
#   false → sem espaço
#            Foo()
csharp_space_between_method_call_name_and_opening_parenthesis = false

# Descrição: Espaço dentro dos parênteses de argumentos na chamada de método
# Valores possíveis:
#   true  → insere espaço dentro dos parênteses
#            Foo( a, b )
#   false → sem espaço dentro
#            Foo(a, b)
csharp_space_between_method_call_parameter_list_parentheses = false

# Descrição: Espaço dentro dos parênteses em declaração de método sem parâmetros
# Valores possíveis:
#   true  → insere espaço dentro
#            void Foo( )
#   false → sem espaço
#            void Foo()
csharp_space_between_method_declaration_empty_parameter_list_parentheses = false

# Descrição: Espaço entre o nome do método e o parêntese de abertura na declaração
# Valores possíveis:
#   true  → insere espaço
#            void Foo (int x)
#   false → sem espaço
#            void Foo(int x)
csharp_space_between_method_declaration_name_and_open_parenthesis = false

# Descrição: Espaço dentro dos parênteses de parâmetros na declaração de método
# Valores possíveis:
#   true  → insere espaço dentro dos parênteses
#            void Foo( int x )
#   false → sem espaço dentro
#            void Foo(int x)
csharp_space_between_method_declaration_parameter_list_parentheses = false

# csharp_space_between_parentheses — Espaços dentro de parênteses.
# Valores possíveis (podem ser combinados com vírgula):
#   false                    → sem espaço em nenhum caso:  (a + b)
#   control_flow_statements  → espaço em if/for/while/...:  if ( x )
#   type_casts               → espaço em cast:              ( int )x
#   expressions              → espaço em expressões gerais: ( a + b )
# Exemplo combinado: control_flow_statements, type_casts
#   if ( x ) { }    var y = ( int )x;
csharp_space_between_parentheses = false

# Descrição: Espaço entre colchetes em acesso a array não vazio
# Valores possíveis:
#   true  → insere espaço dentro dos colchetes
#            arr[ 0 ]
#   false → sem espaço dentro
#            arr[0]
csharp_space_between_square_brackets = false

# -----------------------------------------------------------------------------
# Preferências de quebra de linha (wrapping)
# -----------------------------------------------------------------------------

# Descrição: Mantém blocos de instrução única em uma única linha
# Valores possíveis:
#   true  → permite bloco de uma linha
#            public int X { get; set; }
#   false → força expansão do bloco em múltiplas linhas
csharp_preserve_single_line_blocks = true

# Descrição: Mantém statements únicos na mesma linha sem forçar quebra
# Valores possíveis:
#   true  → permite statement de uma linha
#            if (x) return;
#   false → força o statement para nova linha
csharp_preserve_single_line_statements = true

# =============================================================================
# Whitespace experimental (IDE2000–IDE2006)
# =============================================================================

# Descrição: Permite múltiplas linhas em branco consecutivas no código
# Valores possíveis:
#   true  → permite múltiplas linhas em branco seguidas
#   false → remove linhas em branco consecutivas extras
dotnet_style_allow_multiple_blank_lines_experimental = false:warning

# Descrição: Permite embedded statements (if, for, etc.) na mesma linha
# Valores possíveis:
#   true  → permite if (x) return; na mesma linha
#   false → exige que o statement fique em nova linha
csharp_style_allow_embedded_statements_on_same_line_experimental = false:suggestion

# Descrição: Permite linha em branco entre chaves consecutivas
# Valores possíveis:
#   true  → permite linha em branco entre { e }
#   false → não permite linha em branco entre chaves consecutivas
csharp_style_allow_blank_lines_between_consecutive_braces_experimental = false:suggestion

# Descrição: Permite statement imediatamente após um bloco (sem linha em branco)
# Valores possíveis:
#   true  → permite statement logo após bloco sem linha em branco
#   false → exige linha em branco entre bloco e próxima declaração
dotnet_style_allow_statement_immediately_after_block_experimental = false:suggestion

# Descrição: Permite linha em branco após : de constructor initializer
# Valores possíveis:
#   true  → permite linha em branco após base(...):
#   false → não permite linha em branco após : do initializer
csharp_style_allow_blank_line_after_colon_in_constructor_initializer_experimental = false:suggestion

# Descrição: Permite linha em branco após token de expressão condicional (? ou :)
# Valores possíveis:
#   true  → permite linha em branco após ?
#   false → não permite linha em branco no meio de expressão condicional
csharp_style_allow_blank_line_after_token_in_conditional_expression_experimental = false:warning

# Descrição: Permite linha em branco após token de expressão lambda (=>)
# Valores possíveis:
#   true  → permite linha em branco após =>
#   false → não permite linha em branco após => em lambdas
csharp_style_allow_blank_line_after_token_in_arrow_expression_clause_experimental = false:suggestion

# =============================================================================
# Naming styles (IDE1006)
# =============================================================================
[*.{cs,vb}]

# -----------------------------------------------------------------------------
# Estrutura de naming styles
# Cada estilo tem 4 propriedades (apenas capitalization é obrigatória):
#
#   dotnet_naming_style.<nome>.required_prefix = <prefixo>
#     Define prefixo obrigatório no início do nome
#     Valores: I, T, _, s_, (vazio para sem prefixo)
#     Exemplos: ICustomer, TKey, _name, s_count
#
#   dotnet_naming_style.<nome>.required_suffix = <sufixo>
#     Define sufixo obrigatório no final do nome
#     Valores: Attribute, Exception, EventArgs, (vazio para sem sufixo)
#     Exemplos: RequiredAttribute, ValidationException
#
#   dotnet_naming_style.<nome>.word_separator = <separador>
#     Define separador entre palavras
#     Valores: (vazio) para PascalCase/camelCase, _ para snake_case
#     Exemplos: MyClassName, MAX_CONNECTIONS
#
#   dotnet_naming_style.<nome>.capitalization = <capitalização>  (obrigatório)
#     Valores possíveis:
#       pascal_case  → Primeira letra maiúscula: MyClassName, ProcessOrder
#       camel_case   → Primeira letra minúscula: myVariable, orderCount
#       all_upper    → Todas maiúsculas: MAX_CONNECTIONS, DEFAULT_TIMEOUT
#       all_lower    → Todas minúsculas: filename, url
# ----------------------------------------------------------------------
#
# Exemplos de estilos completos:
#
#   PascalCase (tipos, métodos, propriedades):
#     dotnet_naming_style.pascalcase.capitalization = pascal_case
#     Resultado: MyClass, ProcessOrder
#
#   IPascalCase (interfaces):
#     dotnet_naming_style.ipascalcase.required_prefix = I
#     dotnet_naming_style.ipascalcase.capitalization = pascal_case
#     Resultado: ICustomer, IRepository
#
#   TPascalCase (parâmetros de tipo genérico):
#     dotnet_naming_style.tpascalcase.required_prefix = T
#     dotnet_naming_style.tpascalcase.capitalization = pascal_case
#     Resultado: TKey, TValue, TResult
#
#   _camelCase (campos privados e estáticos):
#     dotnet_naming_style._camelcase.required_prefix = _
#     dotnet_naming_style._camelcase.capitalization = camel_case
#     Resultado: _name, _customerRepository, _instanceCount (estáticos)
#
#   ALL_UPPER (constantes, se preferir diferenciar):
#     dotnet_naming_style.all_upper.word_separator = _
#     dotnet_naming_style.all_upper.capitalization = all_upper
#     Resultado: MAX_CONNECTIONS, DEFAULT_TIMEOUT
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Regras de nomenclatura
# Cada regra tem: severity, symbols (o que se aplica), style (como nomear)
# -----------------------------------------------------------------------------

# Tipos e namespaces → PascalCase
# true: class MyService { }   namespace MyApp.Services { }
dotnet_naming_rule.types_and_namespaces_should_be_pascalcase.severity = warning
dotnet_naming_rule.types_and_namespaces_should_be_pascalcase.symbols = types_and_namespaces
dotnet_naming_rule.types_and_namespaces_should_be_pascalcase.style = pascalcase

# Interfaces → IPascalCase (prefixo I)
# true: interface IRepository { }
dotnet_naming_rule.interfaces_should_be_ipascalcase.severity = warning
dotnet_naming_rule.interfaces_should_be_ipascalcase.symbols = interfaces
dotnet_naming_rule.interfaces_should_be_ipascalcase.style = ipascalcase

# Parâmetros de tipo genérico → TPascalCase (prefixo T)
# true: class Container<TItem> { }
dotnet_naming_rule.type_parameters_should_be_tpascalcase.severity = warning
dotnet_naming_rule.type_parameters_should_be_tpascalcase.symbols = type_parameters
dotnet_naming_rule.type_parameters_should_be_tpascalcase.style = tpascalcase

# Métodos → PascalCase
# true: public void ProcessOrder() { }
dotnet_naming_rule.methods_should_be_pascalcase.severity = warning
dotnet_naming_rule.methods_should_be_pascalcase.symbols = methods
dotnet_naming_rule.methods_should_be_pascalcase.style = pascalcase

# Propriedades → PascalCase
# true: public string FullName { get; set; }
dotnet_naming_rule.properties_should_be_pascalcase.severity = warning
dotnet_naming_rule.properties_should_be_pascalcase.symbols = properties
dotnet_naming_rule.properties_should_be_pascalcase.style = pascalcase

# Eventos → PascalCase
# true: public event EventHandler OrderPlaced;
dotnet_naming_rule.events_should_be_pascalcase.severity = warning
dotnet_naming_rule.events_should_be_pascalcase.symbols = events
dotnet_naming_rule.events_should_be_pascalcase.style = pascalcase

# Variáveis locais → camelCase
# true: int orderCount = 0;
dotnet_naming_rule.local_variables_should_be_camelcase.severity = warning
dotnet_naming_rule.local_variables_should_be_camelcase.symbols = local_variables
dotnet_naming_rule.local_variables_should_be_camelcase.style = camelcase

# Constantes locais → camelCase
# true: const int maxRetries = 3;
dotnet_naming_rule.local_constants_should_be_camelcase.severity = warning
dotnet_naming_rule.local_constants_should_be_camelcase.symbols = local_constants
dotnet_naming_rule.local_constants_should_be_camelcase.style = camelcase

# Parâmetros → camelCase
# true: void Process(string orderName) { }
dotnet_naming_rule.parameters_should_be_camelcase.severity = warning
dotnet_naming_rule.parameters_should_be_camelcase.symbols = parameters
dotnet_naming_rule.parameters_should_be_camelcase.style = camelcase

# Campos públicos/internos → PascalCase
# true: public int MaxItems;
dotnet_naming_rule.public_fields_should_be_pascalcase.severity = warning
dotnet_naming_rule.public_fields_should_be_pascalcase.symbols = public_fields
dotnet_naming_rule.public_fields_should_be_pascalcase.style = pascalcase

# Campos privados/protegidos → _camelCase
# true: private string _customerName;
dotnet_naming_rule.private_fields_should_be__camelcase.severity = warning
dotnet_naming_rule.private_fields_should_be__camelcase.symbols = private_fields
dotnet_naming_rule.private_fields_should_be__camelcase.style = _camelcase

# Campos privados estáticos → _camelCase
# true: private static int _instanceCount;
dotnet_naming_rule.private_static_fields_should_be__camelcase.severity = warning
dotnet_naming_rule.private_static_fields_should_be__camelcase.symbols = private_static_fields
dotnet_naming_rule.private_static_fields_should_be__camelcase.style = _camelcase

# Constantes públicas/internas → PascalCase
# true: public const int MaxRetries = 5;
dotnet_naming_rule.public_constant_fields_should_be_pascalcase.severity = warning
dotnet_naming_rule.public_constant_fields_should_be_pascalcase.symbols = public_constant_fields
dotnet_naming_rule.public_constant_fields_should_be_pascalcase.style = pascalcase

# Constantes privadas/protegidas → PascalCase
# true: private const int BufferSize = 1024;
dotnet_naming_rule.private_constant_fields_should_be_pascalcase.severity = warning
dotnet_naming_rule.private_constant_fields_should_be_pascalcase.symbols = private_constant_fields
dotnet_naming_rule.private_constant_fields_should_be_pascalcase.style = pascalcase

# Campos static readonly públicos/internos → PascalCase
# true: public static readonly TimeSpan DefaultTimeout = TimeSpan.FromSeconds(30);
dotnet_naming_rule.public_static_readonly_fields_should_be_pascalcase.severity = warning
dotnet_naming_rule.public_static_readonly_fields_should_be_pascalcase.symbols = public_static_readonly_fields
dotnet_naming_rule.public_static_readonly_fields_should_be_pascalcase.style = pascalcase

# Campos static readonly privados/protegidos → PascalCase
# true: private static readonly Regex EmailRegex = new(...);
dotnet_naming_rule.private_static_readonly_fields_should_be_pascalcase.severity = warning
dotnet_naming_rule.private_static_readonly_fields_should_be_pascalcase.symbols = private_static_readonly_fields
dotnet_naming_rule.private_static_readonly_fields_should_be_pascalcase.style = pascalcase

# Enums → PascalCase
# true: enum OrderStatus { Pending, Shipped }
dotnet_naming_rule.enums_should_be_pascalcase.severity = warning
dotnet_naming_rule.enums_should_be_pascalcase.symbols = enums
dotnet_naming_rule.enums_should_be_pascalcase.style = pascalcase

# Funções locais → PascalCase
# true: void ProcessOrder() { void ValidateInput() { } }
dotnet_naming_rule.local_functions_should_be_pascalcase.severity = warning
dotnet_naming_rule.local_functions_should_be_pascalcase.symbols = local_functions
dotnet_naming_rule.local_functions_should_be_pascalcase.style = pascalcase

# Membros não-campo (propriedades, eventos, métodos) → PascalCase
dotnet_naming_rule.non_field_members_should_be_pascalcase.severity = warning
dotnet_naming_rule.non_field_members_should_be_pascalcase.symbols = non_field_members
dotnet_naming_rule.non_field_members_should_be_pascalcase.style = pascalcase

# -----------------------------------------------------------------------------
# Especificações de símbolos (o que cada grupo cobre)
# Cada símbolo é definido por 3 propriedades:
#
#   dotnet_naming_symbols.<nome>.applicable_kinds = <tipos>
#     Define QUE tipos de elementos a regra se aplica
#     Valores possíveis (separados por vírgula):
#       namespace     → namespaces
#       class         → classes
#       struct        → structs
#       interface     → interfaces
#       enum          → enums
#       delegate      → delegates
#       event         → eventos
#       field         → campos
#       method        → métodos
#       property      → propriedades
#       type_parameter → parâmetros de tipo genérico (<T>)
#       local         → variáveis locais
#       local_function → funções locais
#       parameter     → parâmetros de método
#
#   dotnet_naming_symbols.<nome>.applicable_accessibilities = <acessibilidade>
#     Define PARA QUAIS acessibilidades a regra se aplica
#     Valores possíveis (separados por vírgula):
#       public            → público (qualquer código pode acessar)
#       internal          → interno (mesmo assembly)
#       private           → privado (mesmo tipo)
#       protected         → protegido (tipo derivado)
#       protected_internal → protegido ou interno
#       private_protected  → protegido E interno
#       local             → escopo local (variáveis locais)
#       *                 → todas as acessibilidades
#
#   dotnet_naming_symbols.<nome>.required_modifiers = <modificadores>
#     Define QUAIS modificadores são obrigatórios (opcional)
#     Valores possíveis (separados por vírgula):
#       static   → membros estáticos
#       const    → constantes
#       readonly → campos readonly
#       abstract → membros abstratos
#       virtual  → membros virtuais
#       override → membros sobrescritos
#       sealed   → membros sealed
#       async    → métodos async
#       (vazio)  → sem requisito de modificador
#
# Exemplos completos:
#
#   Campos públicos (qualquer acessibilidade pública ou interna):
#     dotnet_naming_symbols.public_fields.applicable_kinds = field
#     dotnet_naming_symbols.public_fields.applicable_accessibilities = public, internal
#     dotnet_naming_symbols.public_fields.required_modifiers =
#
#   Campos privados estáticos (deve ter static):
#     dotnet_naming_symbols.private_static_fields.applicable_kinds = field
#     dotnet_naming_symbols.private_static_fields.applicable_accessibilities = private, protected, protected_internal, private_protected
#     dotnet_naming_symbols.private_static_fields.required_modifiers = static
#
#   Constantes privadas (deve ter const):
#     dotnet_naming_symbols.private_constant_fields.applicable_kinds = field
#     dotnet_naming_symbols.private_constant_fields.applicable_accessibilities = private, protected, protected_internal, private_protected
#     dotnet_naming_symbols.private_constant_fields.required_modifiers = const
# -----------------------------------------------------------------------------

dotnet_naming_symbols.interfaces.applicable_kinds = interface
dotnet_naming_symbols.interfaces.applicable_accessibilities = public, internal, private, protected, protected_internal, private_protected
dotnet_naming_symbols.interfaces.required_modifiers =

dotnet_naming_symbols.enums.applicable_kinds = enum
dotnet_naming_symbols.enums.applicable_accessibilities = public, internal, private, protected, protected_internal, private_protected
dotnet_naming_symbols.enums.required_modifiers =

dotnet_naming_symbols.events.applicable_kinds = event
dotnet_naming_symbols.events.applicable_accessibilities = public, internal, private, protected, protected_internal, private_protected
dotnet_naming_symbols.events.required_modifiers =

dotnet_naming_symbols.methods.applicable_kinds = method
dotnet_naming_symbols.methods.applicable_accessibilities = public, internal, private, protected, protected_internal, private_protected
dotnet_naming_symbols.methods.required_modifiers =

dotnet_naming_symbols.properties.applicable_kinds = property
dotnet_naming_symbols.properties.applicable_accessibilities = public, internal, private, protected, protected_internal, private_protected
dotnet_naming_symbols.properties.required_modifiers =

dotnet_naming_symbols.public_fields.applicable_kinds = field
dotnet_naming_symbols.public_fields.applicable_accessibilities = public, internal
dotnet_naming_symbols.public_fields.required_modifiers =

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private, protected, protected_internal, private_protected
dotnet_naming_symbols.private_fields.required_modifiers =

dotnet_naming_symbols.private_static_fields.applicable_kinds = field
dotnet_naming_symbols.private_static_fields.applicable_accessibilities = private, protected, protected_internal, private_protected
dotnet_naming_symbols.private_static_fields.required_modifiers = static

dotnet_naming_symbols.types_and_namespaces.applicable_kinds = namespace, class, struct, interface, enum
dotnet_naming_symbols.types_and_namespaces.applicable_accessibilities = public, internal, private, protected, protected_internal, private_protected
dotnet_naming_symbols.types_and_namespaces.required_modifiers =

dotnet_naming_symbols.non_field_members.applicable_kinds = property, event, method
dotnet_naming_symbols.non_field_members.applicable_accessibilities = public, internal, private, protected, protected_internal, private_protected
dotnet_naming_symbols.non_field_members.required_modifiers =

dotnet_naming_symbols.type_parameters.applicable_kinds = type_parameter
dotnet_naming_symbols.type_parameters.applicable_accessibilities = *
dotnet_naming_symbols.type_parameters.required_modifiers =

dotnet_naming_symbols.private_constant_fields.applicable_kinds = field
dotnet_naming_symbols.private_constant_fields.applicable_accessibilities = private, protected, protected_internal, private_protected
dotnet_naming_symbols.private_constant_fields.required_modifiers = const

dotnet_naming_symbols.local_variables.applicable_kinds = local
dotnet_naming_symbols.local_variables.applicable_accessibilities = local
dotnet_naming_symbols.local_variables.required_modifiers =

dotnet_naming_symbols.local_constants.applicable_kinds = local
dotnet_naming_symbols.local_constants.applicable_accessibilities = local
dotnet_naming_symbols.local_constants.required_modifiers = const

dotnet_naming_symbols.parameters.applicable_kinds = parameter
dotnet_naming_symbols.parameters.applicable_accessibilities = *
dotnet_naming_symbols.parameters.required_modifiers =

dotnet_naming_symbols.public_constant_fields.applicable_kinds = field
dotnet_naming_symbols.public_constant_fields.applicable_accessibilities = public, internal
dotnet_naming_symbols.public_constant_fields.required_modifiers = const

dotnet_naming_symbols.public_static_readonly_fields.applicable_kinds = field
dotnet_naming_symbols.public_static_readonly_fields.applicable_accessibilities = public, internal
dotnet_naming_symbols.public_static_readonly_fields.required_modifiers = readonly, static

dotnet_naming_symbols.private_static_readonly_fields.applicable_kinds = field
dotnet_naming_symbols.private_static_readonly_fields.applicable_accessibilities = private, protected, protected_internal, private_protected
dotnet_naming_symbols.private_static_readonly_fields.required_modifiers = readonly, static

dotnet_naming_symbols.local_functions.applicable_kinds = local_function
dotnet_naming_symbols.local_functions.applicable_accessibilities = *
dotnet_naming_symbols.local_functions.required_modifiers =

# -----------------------------------------------------------------------------
# Estilos de nomenclatura
# Cada estilo define: required_prefix, required_suffix, word_separator, capitalization
#
# capitalization — Valores possíveis:
#   pascal_case       → PrimeiraLetraMaiúscula:  MyClassName
#   camel_case        → primeiraLetraMinúscula:  myLocalVariable
#   first_word_upper  → Primeira palavra maiúscula, resto minúsculo: My class name
#   all_upper         → TUDO_MAIÚSCULO (útil com word_separator=_): MY_CONSTANT
#   all_lower         → tudo_minúsculo: my_variable

# PascalCase: MyClassName
dotnet_naming_style.pascalcase.required_prefix =
dotnet_naming_style.pascalcase.required_suffix =
dotnet_naming_style.pascalcase.word_separator =
dotnet_naming_style.pascalcase.capitalization = pascal_case

# IPascalCase: IMyInterface
dotnet_naming_style.ipascalcase.required_prefix = I
dotnet_naming_style.ipascalcase.required_suffix =
dotnet_naming_style.ipascalcase.word_separator =
dotnet_naming_style.ipascalcase.capitalization = pascal_case

# TPascalCase: TMyTypeParam
dotnet_naming_style.tpascalcase.required_prefix = T
dotnet_naming_style.tpascalcase.required_suffix =
dotnet_naming_style.tpascalcase.word_separator =
dotnet_naming_style.tpascalcase.capitalization = pascal_case

# _camelCase: _myPrivateField
dotnet_naming_style._camelcase.required_prefix = _
dotnet_naming_style._camelcase.required_suffix =
dotnet_naming_style._camelcase.word_separator =
dotnet_naming_style._camelcase.capitalization = camel_case

# camelCase: myLocalVariable
dotnet_naming_style.camelcase.required_prefix =
dotnet_naming_style.camelcase.required_suffix =
dotnet_naming_style.camelcase.word_separator =
dotnet_naming_style.camelcase.capitalization = camel_case

# =============================================================================
# Severidade explícita de diagnósticos de estilo (IDE)
# =============================================================================
[*.{cs,vb}]

# -----------------------------------------------------------------------------
# Explicação de diagnósticos IDE
# Diagnósticos IDE são regras de estilo específicas do Visual Studio.
# Diferente dos CAXXXX (Quality Rules), os IDEXXXX focam em:
#   - Simplificações de código
#   - Remoção de código redundante
#   - Refactorings sugeridos
#   - Estilo de programação
#
# Níveis de severidade:
#   none       → Desativa completamente (não aparece, não aplica no format)
#   silent     → Invisível na IDE (só refactoring), não aplica no format
#   suggestion → Aparece como sugestão leve, aplica com dotnet format --severity info
#   warning    → Aparece como aviso, aplica no dotnet format padrão
#   error      → Erro de build, sempre aplicado
#
# Formato:
#   dotnet_diagnostic.IDE<XXXX>.severity = <severidade>
#
# Dicas:
#   - use 'suggestion' para refactorings opcionais
#   - use 'none' para desativar regras conflitantes ou indesejadas
#   - use 'warning' para impor estilo obrigatório (mas cuidado com refatorações automáticas)
#   - use 'silent' para ter a regra disponível apenas via refactoring manual
# -----------------------------------------------------------------------------

# IDE0001: Simplifica nome (ex: System.String -> string) — já coberto por IDE0049
dotnet_diagnostic.IDE0001.severity = warning

# IDE0002: Simplifica acesso a membro (ex: MyClass.MyClass.Method -> MyClass.Method)
dotnet_diagnostic.IDE0002.severity = warning

# IDE0004: Remove cast desnecessário (ex: (int)intVar -> intVar)
dotnet_diagnostic.IDE0004.severity = warning

# IDE0005: Remove using desnecessário
dotnet_diagnostic.IDE0005.severity = warning

# IDE0010: Adiciona cases faltando no switch statement
dotnet_diagnostic.IDE0010.severity = warning

# IDE0035: Remove código inacessível (unreachable code)
dotnet_diagnostic.IDE0035.severity = warning

# IDE0044: Adiciona readonly em campo que não é reatribuído após o construtor
dotnet_diagnostic.IDE0044.severity = suggestion

# IDE0046: Simplifica return com ternário — desativado pois pode reduzir legibilidade
dotnet_diagnostic.IDE0046.severity = none

# IDE0050: Converte anonymous type para tuple
dotnet_diagnostic.IDE0050.severity = suggestion

# IDE0051: Remove membro privado não usado
dotnet_diagnostic.IDE0051.severity = suggestion

# IDE0052: Remove membro privado não lido (apenas escrito, nunca lido)
dotnet_diagnostic.IDE0052.severity = suggestion

# IDE0064: Torna campos de struct graváveis — structs que têm campo 'readonly' mas atribuem 'this = ...' fora do construtor
dotnet_diagnostic.IDE0064.severity = suggestion

# IDE0070: Usa System.HashCode.Combine em vez de lógica customizada de hash (qualquer algoritmo manual, não apenas XOR)
dotnet_diagnostic.IDE0070.severity = suggestion

# IDE0072: Adiciona cases faltando em switch expression
dotnet_diagnostic.IDE0072.severity = warning

# IDE0076: Remove SuppressMessageAttribute global inválido
dotnet_diagnostic.IDE0076.severity = suggestion

# IDE0077: Evita formato legado em SuppressMessageAttribute global
dotnet_diagnostic.IDE0077.severity = suggestion

# IDE0079: Remove suppression desnecessária (#pragma warning disable sem violação real)
dotnet_diagnostic.IDE0079.severity = warning

# IDE0080: Remove suppression operator desnecessário (!)
dotnet_diagnostic.IDE0080.severity = warning

# IDE0082: Converte typeof(T).Name para nameof(T) — somente quando os nomes são idênticos (sem opções de configuração)
# Antes: typeof(MyType).Name   Depois: nameof(MyType)
dotnet_diagnostic.IDE0082.severity = suggestion

# IDE0100: Remove comparação booleana desnecessária com true/false (sem opções de configuração)
# Antes: if (b == true) { }  /  if (M() != false) { }   Depois: if (b) { }  /  if (M()) { }
dotnet_diagnostic.IDE0100.severity = suggestion

# IDE0110: Remove discard pattern desnecessário em switch — 'case int _:' vira 'case int:' (não é o _ = Foo())
dotnet_diagnostic.IDE0110.severity = suggestion

# IDE0120: Simplifica expressão LINQ
dotnet_diagnostic.IDE0120.severity = suggestion

# IDE0121: Simplifica type check e cast em LINQ
dotnet_diagnostic.IDE0121.severity = suggestion

# IDE0240: Diretiva nullable é redundante (#nullable enable quando já está habilitada)
dotnet_diagnostic.IDE0240.severity = suggestion

# IDE0241: Diretiva nullable é desnecessária (#nullable disable quando já está desabilitada)
dotnet_diagnostic.IDE0241.severity = suggestion

# IDE0280: Usa nameof em atributos que recebem nome de parâmetro (NotNullIfNotNull, NotNullWhen, CallerArgumentExpression)
# Antes: [NotNullIfNotNull("input")]   Depois: [NotNullIfNotNull(nameof(input))]
dotnet_diagnostic.IDE0280.severity = suggestion

# IDE0370: Remove null-forgiving operator (!) desnecessário — quando o compilador já sabe que o valor não é null
# Antes: List<string> names = new()!;   Depois: List<string> names = new();
dotnet_diagnostic.IDE0370.severity = suggestion

# IDE0380: Remove modificador unsafe desnecessário
dotnet_diagnostic.IDE0380.severity = suggestion

# IDE3000: Copilot — sugestão de implementação automática (informativo)
dotnet_diagnostic.IDE3000.severity = none

# =============================================================================
# Quality Rules (CA) — Design
# Severidade: none | silent | suggestion | warning | error
# =============================================================================
[*.{cs,vb}]

# CA1000: Não declare membros estáticos em tipos genéricos
# Errado: MyGeneric<T>.StaticMethod() — requer especificar T
dotnet_diagnostic.CA1000.severity = suggestion

# CA1001: Tipos que possuem campos IDisposable devem implementar IDisposable
dotnet_diagnostic.CA1001.severity = suggestion

# CA1002: Não exponha List<T> — use IList<T>, ICollection<T> ou IReadOnlyList<T>
dotnet_diagnostic.CA1002.severity = suggestion

# CA1003: Use instâncias de EventHandler<T> genérico para eventos
dotnet_diagnostic.CA1003.severity = suggestion

# CA1005: Evite muitos parâmetros de tipo em tipos genéricos (mais de 2)
dotnet_diagnostic.CA1005.severity = suggestion

# CA1008: Enums devem ter valor zero
# true: enum Status { None = 0, Active = 1 }
dotnet_diagnostic.CA1008.severity = suggestion

# CA1010: Coleções devem implementar interface genérica (IEnumerable<T>)
dotnet_diagnostic.CA1010.severity = suggestion

# CA1012: Tipos abstratos não devem ter construtores públicos
dotnet_diagnostic.CA1012.severity = suggestion

# CA1014: Marque assemblies com CLSCompliantAttribute
dotnet_diagnostic.CA1014.severity = none

# CA1016: Marque assemblies com AssemblyVersionAttribute
dotnet_diagnostic.CA1016.severity = suggestion

# CA1017: Marque assemblies com ComVisibleAttribute
dotnet_diagnostic.CA1017.severity = none

# CA1018: Marque atributos com AttributeUsageAttribute
dotnet_diagnostic.CA1018.severity = suggestion

# CA1019: Defina accessors para argumentos de atributos (propriedades para ctor args)
dotnet_diagnostic.CA1019.severity = suggestion

# CA1021: Evite parâmetros out
dotnet_diagnostic.CA1021.severity = none

# CA1024: Use propriedades onde apropriado (métodos Get* sem parâmetros)
dotnet_diagnostic.CA1024.severity = suggestion

# CA1027: Marque enums com FlagsAttribute quando valores podem ser combinados
dotnet_diagnostic.CA1027.severity = suggestion

# CA1028: Armazenamento de enum deve ser Int32 (evite byte/short)
dotnet_diagnostic.CA1028.severity = suggestion

# CA1030: Use eventos onde apropriado (métodos chamados Fire*/Raise*/Trigger*)
dotnet_diagnostic.CA1030.severity = suggestion

# CA1031: Não capture exceções gerais (Exception); capture tipos específicos
dotnet_diagnostic.CA1031.severity = suggestion

# CA1032: Implemente construtores padrão de exceção (Message, inner, serialization)
dotnet_diagnostic.CA1032.severity = suggestion

# CA1033: Métodos de interface devem ser acessíveis por tipos derivados
dotnet_diagnostic.CA1033.severity = suggestion

# CA1034: Tipos aninhados não devem ser visíveis externamente
dotnet_diagnostic.CA1034.severity = suggestion

# CA1036: Implemente Equals e operadores ao implementar IComparable
dotnet_diagnostic.CA1036.severity = suggestion

# CA1040: Evite interfaces vazias (sem membros)
dotnet_diagnostic.CA1040.severity = suggestion

# CA1041: Forneça mensagem em ObsoleteAttribute
dotnet_diagnostic.CA1041.severity = suggestion

# CA1043: Use int ou string como índice de indexers
dotnet_diagnostic.CA1043.severity = suggestion

# CA1044: Propriedades não devem ser somente escrita (sem get)
dotnet_diagnostic.CA1044.severity = suggestion

# CA1045: Não passe tipos por referência (out/ref) em APIs públicas
dotnet_diagnostic.CA1045.severity = none

# CA1046: Não sobrecarregue operator== em tipos de referência
dotnet_diagnostic.CA1046.severity = suggestion

# CA1047: Não declare membros protected em tipos sealed
dotnet_diagnostic.CA1047.severity = suggestion

# CA1050: Declare tipos em namespaces (não no namespace global)
dotnet_diagnostic.CA1050.severity = suggestion

# CA1051: Não declare campos de instância visíveis; use propriedades
dotnet_diagnostic.CA1051.severity = suggestion

# CA1052: Tipos static holder devem ser sealed
dotnet_diagnostic.CA1052.severity = suggestion

# CA1053: Tipos static holder não devem ter construtores
dotnet_diagnostic.CA1053.severity = suggestion

# CA1054: Parâmetros URI não devem ser string; use Uri
dotnet_diagnostic.CA1054.severity = suggestion

# CA1055: Valores de retorno URI não devem ser string; use Uri
dotnet_diagnostic.CA1055.severity = suggestion

# CA1056: Propriedades URI não devem ser string; use Uri
dotnet_diagnostic.CA1056.severity = suggestion

# CA1058: Tipos não devem estender certos tipos base (ApplicationException etc.)
dotnet_diagnostic.CA1058.severity = suggestion

# CA1060: Mova P/Invokes para classe NativeMethods
dotnet_diagnostic.CA1060.severity = none

# CA1061: Não oculte métodos de classe base
dotnet_diagnostic.CA1061.severity = suggestion

# CA1062: Valide argumentos de métodos públicos (null check)
dotnet_diagnostic.CA1062.severity = none

# CA1063: Implemente IDisposable corretamente (padrão Dispose)
dotnet_diagnostic.CA1063.severity = suggestion

# CA1064: Exceções devem ser públicas
dotnet_diagnostic.CA1064.severity = suggestion

# CA1065: Não lance exceções em locais inesperados (getters, operadores)
dotnet_diagnostic.CA1065.severity = suggestion

# CA1066: Implemente IEquatable<T> ao sobrescrever Equals
dotnet_diagnostic.CA1066.severity = suggestion

# CA1067: Sobrescreva Equals ao implementar IEquatable<T>
dotnet_diagnostic.CA1067.severity = suggestion

# CA1068: Parâmetros CancellationToken devem vir por último
dotnet_diagnostic.CA1068.severity = suggestion

# CA1069: Enums não devem ter valores duplicados
dotnet_diagnostic.CA1069.severity = suggestion

# CA1070: Não declare campos de evento como virtual
dotnet_diagnostic.CA1070.severity = suggestion

# =============================================================================
# Quality Rules (CA) — Globalização
# =============================================================================

# CA1200: Evite usar tags cref com prefixo em documentação XML
dotnet_diagnostic.CA1200.severity = suggestion

# CA1303: Não passe literais como parâmetros localizáveis
dotnet_diagnostic.CA1303.severity = none

# CA1304: Especifique CultureInfo em métodos que aceitam esse parâmetro
dotnet_diagnostic.CA1304.severity = suggestion

# CA1305: Especifique IFormatProvider em métodos de formatação
dotnet_diagnostic.CA1305.severity = suggestion

# CA1307: Especifique StringComparison para clareza
dotnet_diagnostic.CA1307.severity = suggestion

# CA1308: Normalize strings para maiúsculas (não minúsculas)
dotnet_diagnostic.CA1308.severity = suggestion

# CA1309: Use StringComparison.Ordinal em comparações não-linguísticas
dotnet_diagnostic.CA1309.severity = suggestion

# CA1310: Especifique StringComparison para correção (evite comparação culture-specific)
dotnet_diagnostic.CA1310.severity = suggestion

# CA1311: Especifique cultura ou use versão invariante em ToUpper/ToLower
dotnet_diagnostic.CA1311.severity = suggestion

# =============================================================================
# Quality Rules (CA) — Interoperabilidade
# =============================================================================

# CA1401: P/Invokes não devem ser visíveis publicamente
dotnet_diagnostic.CA1401.severity = suggestion

# CA1416: Valide compatibilidade de plataforma para APIs específicas de SO
dotnet_diagnostic.CA1416.severity = suggestion

# CA1417: Não use OutAttribute em parâmetros string de P/Invokes
dotnet_diagnostic.CA1417.severity = suggestion

# CA1418: Use string de plataforma válida em atributos de compatibilidade
dotnet_diagnostic.CA1418.severity = suggestion

# CA1419: Forneça construtor sem parâmetros para tipos derivados de SafeHandle
dotnet_diagnostic.CA1419.severity = suggestion

# CA1420: Propriedade/tipo/atributo requer runtime marshalling
dotnet_diagnostic.CA1420.severity = suggestion

# CA1421: Método usa runtime marshalling com DisableRuntimeMarshallingAttribute
dotnet_diagnostic.CA1421.severity = suggestion

# CA1422: Valide compatibilidade de plataforma (obsolescência por SO/versão)
dotnet_diagnostic.CA1422.severity = suggestion

# =============================================================================
# Quality Rules (CA) — Manutenibilidade
# =============================================================================

# CA1501: Evite herança excessiva (mais de 4 níveis)
dotnet_diagnostic.CA1501.severity = suggestion

# CA1502: Evite complexidade ciclomática excessiva
dotnet_diagnostic.CA1502.severity = suggestion

# CA1505: Evite código de difícil manutenção (índice de manutenibilidade baixo)
dotnet_diagnostic.CA1505.severity = suggestion

# CA1506: Evite acoplamento excessivo entre classes
dotnet_diagnostic.CA1506.severity = suggestion

# CA1507: Use nameof em vez de string literal para nomes de membro
# true: nameof(MyProp)   false: "MyProp"
dotnet_diagnostic.CA1507.severity = suggestion

# CA1508: Evite código condicional morto (always true/false)
dotnet_diagnostic.CA1508.severity = suggestion

# CA1509: Entrada inválida no arquivo de configuração de métricas de código
dotnet_diagnostic.CA1509.severity = suggestion

# =============================================================================
# Quality Rules (CA) — Throw helpers (CA1510–CA1513)
# =============================================================================

# CA1510: Use ArgumentNullException.ThrowIfNull em vez de if+throw block
# true: ArgumentNullException.ThrowIfNull(arg);
dotnet_diagnostic.CA1510.severity = suggestion

# CA1511: Use ArgumentException.ThrowIfNullOrEmpty/ThrowIfNullOrWhiteSpace
dotnet_diagnostic.CA1511.severity = suggestion

# CA1512: Use ArgumentOutOfRangeException throw helpers (ThrowIfZero, ThrowIfNegative, ThrowIfGreaterThan, ThrowIfEqual, etc.)
dotnet_diagnostic.CA1512.severity = suggestion

# CA1513: Use ObjectDisposedException.ThrowIf
dotnet_diagnostic.CA1513.severity = suggestion

# CA1514: Evite argumento de comprimento redundante em Slice/Substring
dotnet_diagnostic.CA1514.severity = suggestion

# CA1515: Considere tornar tipos públicos internos em aplicativos (não bibliotecas)
dotnet_diagnostic.CA1515.severity = none

# CA1516: Use intrínsecos cross-platform em vez de específicos de plataforma
dotnet_diagnostic.CA1516.severity = suggestion

# =============================================================================
# Quality Rules (CA) — Nomenclatura
# =============================================================================

# CA1700: Não nomeie valores de enum como 'Reserved'
dotnet_diagnostic.CA1700.severity = suggestion

# CA1707: Identificadores não devem conter underscores (exceto campos privados)
dotnet_diagnostic.CA1707.severity = none

# CA1708: Identificadores devem diferir por mais do que capitalização
dotnet_diagnostic.CA1708.severity = suggestion

# CA1710: Identificadores devem ter sufixo correto (Collection, Dictionary, etc.)
dotnet_diagnostic.CA1710.severity = suggestion

# CA1711: Identificadores não devem ter sufixo incorreto (Enum, Flag, etc.)
dotnet_diagnostic.CA1711.severity = suggestion

# CA1712: Não prefixe valores de enum com o nome do tipo
# Errado: enum Color { ColorRed, ColorBlue }   Correto: enum Color { Red, Blue }
dotnet_diagnostic.CA1712.severity = suggestion

# CA1713: Eventos não devem ter prefixo Before/After
dotnet_diagnostic.CA1713.severity = suggestion

# CA1714: Enums com FlagsAttribute devem ter nomes plurais
dotnet_diagnostic.CA1714.severity = suggestion

# CA1715: Identificadores devem ter prefixo correto (I para interface, T para type param)
dotnet_diagnostic.CA1715.severity = suggestion

# CA1716: Identificadores não devem coincidir com palavras-chave de linguagens
dotnet_diagnostic.CA1716.severity = suggestion

# CA1717: Apenas enums com FlagsAttribute devem ter nomes plurais
dotnet_diagnostic.CA1717.severity = suggestion

# CA1720: Identificadores não devem conter nomes de tipos (string, int, etc.)
dotnet_diagnostic.CA1720.severity = suggestion

# CA1721: Nomes de propriedades não devem coincidir com métodos Get*
dotnet_diagnostic.CA1721.severity = suggestion

# CA1724: Nomes de tipos não devem coincidir com namespaces do .NET
dotnet_diagnostic.CA1724.severity = suggestion

# CA1725: Nomes de parâmetros devem coincidir com a declaração base
dotnet_diagnostic.CA1725.severity = suggestion

# CA1727: Use PascalCase para placeholders nomeados em templates de log
dotnet_diagnostic.CA1727.severity = suggestion

# =============================================================================
# Quality Rules (CA) — Performance
# =============================================================================

# CA1802: Use literais (const) onde o valor é computável em tempo de compilação
# true: const int Max = 10;   false: static readonly int Max = 10;
dotnet_diagnostic.CA1802.severity = suggestion

# CA1805: Não inicialize campos com valor padrão (já são zero/null/false por padrão)
dotnet_diagnostic.CA1805.severity = suggestion

# CA1806: Não ignore resultados de método (HRESULT, string criada, etc.)
dotnet_diagnostic.CA1806.severity = suggestion

# CA1810: Inicialize campos estáticos de tipo de referência inline (evite static constructor)
dotnet_diagnostic.CA1810.severity = suggestion

# CA1812: Evite classes internas não instanciadas
dotnet_diagnostic.CA1812.severity = suggestion

# CA1813: Evite atributos não-sealed (afeta performance de reflexão)
dotnet_diagnostic.CA1813.severity = suggestion

# CA1814: Prefira jagged arrays a arrays multidimensionais
dotnet_diagnostic.CA1814.severity = suggestion

# CA1815: Implemente Equals e operator== em tipos de valor
dotnet_diagnostic.CA1815.severity = suggestion

# CA1816: Chame GC.SuppressFinalize corretamente no Dispose
dotnet_diagnostic.CA1816.severity = suggestion

# CA1819: Propriedades não devem retornar arrays (retorne cópia ou use ReadOnlyCollection)
dotnet_diagnostic.CA1819.severity = suggestion

# CA1820: Teste strings vazias usando string.Length ou string.IsNullOrEmpty
# true: s.Length == 0   false: s == ""
dotnet_diagnostic.CA1820.severity = suggestion

# CA1821: Remova finalizadores vazios
dotnet_diagnostic.CA1821.severity = suggestion

# CA1822: Marque membros como static quando não acessam dados de instância
dotnet_diagnostic.CA1822.severity = suggestion

# CA1823: Evite campos privados não utilizados
dotnet_diagnostic.CA1823.severity = suggestion

# CA1824: Marque assemblies com NeutralResourcesLanguageAttribute
dotnet_diagnostic.CA1824.severity = suggestion

# CA1825: Evite alocações de array de comprimento zero; use Array.Empty<T>()
# true: Array.Empty<int>()   false: new int[0]
dotnet_diagnostic.CA1825.severity = suggestion

# CA1826: Use propriedade em vez de método LINQ Enumerable equivalente
# true: list.Count   false: list.Count()
dotnet_diagnostic.CA1826.severity = suggestion

# CA1827: Não use Count/LongCount quando Any pode ser usado
# true: list.Any()   false: list.Count() > 0
dotnet_diagnostic.CA1827.severity = suggestion

# CA1828: Não use CountAsync/LongCountAsync quando AnyAsync pode ser usado
dotnet_diagnostic.CA1828.severity = suggestion

# CA1829: Use Length/Count em vez de Enumerable.Count()
dotnet_diagnostic.CA1829.severity = suggestion

# CA1830: Prefira strongly-typed overloads de Append/Insert no StringBuilder
dotnet_diagnostic.CA1830.severity = suggestion

# CA1831: Use AsSpan em vez de indexer de intervalo em strings quando adequado
dotnet_diagnostic.CA1831.severity = suggestion

# CA1832: Use AsSpan/AsMemory em vez de indexer de intervalo para ReadOnlySpan/ReadOnlyMemory
dotnet_diagnostic.CA1832.severity = suggestion

# CA1833: Use AsSpan/AsMemory em vez de indexer de intervalo para Span/Memory
dotnet_diagnostic.CA1833.severity = suggestion

# CA1834: Use StringBuilder.Append(char) para strings com um único caractere
dotnet_diagnostic.CA1834.severity = suggestion

# CA1835: Prefira sobrecargas baseadas em Memory<T> para ReadAsync/WriteAsync
dotnet_diagnostic.CA1835.severity = suggestion

# CA1836: Prefira IsEmpty a Count quando disponível
dotnet_diagnostic.CA1836.severity = suggestion

# CA1837: Use Environment.ProcessId em vez de Process.GetCurrentProcess().Id
dotnet_diagnostic.CA1837.severity = suggestion

# CA1838: Evite parâmetros StringBuilder em P/Invokes
dotnet_diagnostic.CA1838.severity = suggestion

# CA1839: Use Environment.ProcessPath em vez de Process.GetCurrentProcess().MainModule.FileName
dotnet_diagnostic.CA1839.severity = suggestion

# CA1840: Use Environment.CurrentManagedThreadId em vez de Thread.CurrentThread.ManagedThreadId
dotnet_diagnostic.CA1840.severity = suggestion

# CA1841: Prefira ContainsKey/ContainsValue a Contains em Keys/Values do Dictionary
dotnet_diagnostic.CA1841.severity = suggestion

# CA1842: Não use Task.WhenAll com uma única tarefa
dotnet_diagnostic.CA1842.severity = suggestion

# CA1843: Não use Task.WaitAll com uma única tarefa
dotnet_diagnostic.CA1843.severity = suggestion

# CA1844: Forneça overrides async baseados em Memory ao derivar de Stream
dotnet_diagnostic.CA1844.severity = suggestion

# CA1845: Use AsSpan + string.Concat em vez de Substring + concatenação
dotnet_diagnostic.CA1845.severity = suggestion

# CA1846: Prefira AsSpan a Substring (AsSpan é O(1), Substring é O(n))
dotnet_diagnostic.CA1846.severity = suggestion

# CA1847: Use literal char em vez de string de um caractere em Contains/IndexOf
# true: s.Contains('.')   false: s.Contains(".")
dotnet_diagnostic.CA1847.severity = suggestion

# CA1848: Use delegates LoggerMessage para log de alta performance
dotnet_diagnostic.CA1848.severity = none

# CA1849: Chame métodos async dentro de métodos async
# true: await stream.ReadAsync(...)   false: stream.Read(...) dentro de método async
dotnet_diagnostic.CA1849.severity = suggestion

# CA1850: Prefira método estático HashData a instância HashAlgorithm.ComputeHash
dotnet_diagnostic.CA1850.severity = suggestion

# CA1851: Possíveis múltiplas enumerações de IEnumerable — lazy evaluation pode ser executada várias vezes (use List/Array para materializar)
dotnet_diagnostic.CA1851.severity = suggestion

# CA1852: Torne sealed tipos internos que não têm subtipos na assembly — permite JIT otimizar virtual dispatch
dotnet_diagnostic.CA1852.severity = suggestion

# CA1853: Chamada desnecessária a Dictionary.ContainsKey antes de Remove
# true: dict.Remove(key)   false: if (dict.ContainsKey(key)) dict.Remove(key)
dotnet_diagnostic.CA1853.severity = suggestion

# CA1854: Prefira TryGetValue a ContainsKey + indexer no Dictionary
# true: dict.TryGetValue(key, out var v)   false: if (dict.ContainsKey(key)) v = dict[key]
dotnet_diagnostic.CA1854.severity = suggestion

# CA1855: Use Span<T>.Clear() em vez de Span<T>.Fill(default)
dotnet_diagnostic.CA1855.severity = suggestion

# CA1856: Uso incorreto do atributo ConstantExpected
dotnet_diagnostic.CA1856.severity = suggestion

# CA1857: Parâmetro espera constante para performance ideal (ConstantExpected)
dotnet_diagnostic.CA1857.severity = suggestion

# CA1858: Use StartsWith em vez de IndexOf para verificar prefixo
# true: s.StartsWith("abc")   false: s.IndexOf("abc") == 0
dotnet_diagnostic.CA1858.severity = suggestion

# CA1859: Use tipos concretos em vez de interfaces/abstratos para melhor performance
dotnet_diagnostic.CA1859.severity = suggestion

# CA1860: Evite Enumerable.Any() — prefira Length/Count/IsEmpty
dotnet_diagnostic.CA1860.severity = suggestion

# CA1861: Evite arrays constantes como argumentos (crie campo static readonly)
dotnet_diagnostic.CA1861.severity = suggestion

# CA1862: Use sobrecargas StringComparison para comparação case-insensitive
# true: s.Equals(other, StringComparison.OrdinalIgnoreCase)
# false: s.ToLower() == other.ToLower()
dotnet_diagnostic.CA1862.severity = suggestion

# CA1863: Use CompositeFormat em cache para String.Format de alta frequência
dotnet_diagnostic.CA1863.severity = suggestion

# CA1864: Prefira TryAdd a ContainsKey + Add no Dictionary
dotnet_diagnostic.CA1864.severity = suggestion

# CA1865-CA1867: Use char overload em vez de string de um caractere
dotnet_diagnostic.CA1865.severity = suggestion
dotnet_diagnostic.CA1866.severity = suggestion
dotnet_diagnostic.CA1867.severity = suggestion

# CA1868: Chamada desnecessária a Contains antes de Add/Remove em sets
dotnet_diagnostic.CA1868.severity = suggestion

# CA1869: Armazene em cache e reutilize instâncias de JsonSerializerOptions
dotnet_diagnostic.CA1869.severity = suggestion

# CA1870: Use instância em cache de SearchValues<T>
dotnet_diagnostic.CA1870.severity = suggestion

# CA1871: Não passe struct nullable para ArgumentNullException.ThrowIfNull
dotnet_diagnostic.CA1871.severity = suggestion

# CA1872: Prefira Convert.ToHexString a BitConverter.ToString + Replace + ToLower
dotnet_diagnostic.CA1872.severity = suggestion

# CA1873: Evite avaliação potencialmente cara de argumentos de log
dotnet_diagnostic.CA1873.severity = suggestion

# CA1874: Use Regex.IsMatch em vez de Regex.Match(...).Success
dotnet_diagnostic.CA1874.severity = suggestion

# CA1875: Use Regex.Count em vez de Regex.Matches(...).Count
dotnet_diagnostic.CA1875.severity = suggestion

# CA1877: Use overloads de Path.Combine/Path.Join com mais argumentos
dotnet_diagnostic.CA1877.severity = suggestion

# =============================================================================
# Quality Rules (CA) — Confiabilidade
# =============================================================================

# CA2000: Descarte objetos antes de perder o escopo
dotnet_diagnostic.CA2000.severity = suggestion

# CA2002: Não use lock em objetos com identidade fraca (string, Type, etc.)
dotnet_diagnostic.CA2002.severity = suggestion

# CA2007: Não aguarde Task diretamente; use ConfigureAwait(false) em bibliotecas
dotnet_diagnostic.CA2007.severity = none

# CA2008: Não crie tasks sem passar TaskScheduler
dotnet_diagnostic.CA2008.severity = suggestion

# CA2009: Não chame ToImmutableCollection em valor já imutável
dotnet_diagnostic.CA2009.severity = suggestion

# CA2011: Não atribua propriedade dentro de seu próprio setter (loop infinito)
dotnet_diagnostic.CA2011.severity = suggestion

# CA2012: Use ValueTask corretamente (não consume múltiplas vezes)
dotnet_diagnostic.CA2012.severity = suggestion

# CA2013: Não use ReferenceEquals com tipos de valor (causa boxing)
dotnet_diagnostic.CA2013.severity = suggestion

# CA2014: Não use stackalloc em loops (stack overflow)
dotnet_diagnostic.CA2014.severity = suggestion

# CA2015: Não defina finalizadores para tipos derivados de MemoryManager<T>
dotnet_diagnostic.CA2015.severity = suggestion

# CA2016: Encaminhe o parâmetro CancellationToken para métodos que o aceitam
dotnet_diagnostic.CA2016.severity = suggestion

# CA2017: Incompatibilidade de contagem de parâmetros em template de log
dotnet_diagnostic.CA2017.severity = suggestion

# CA2018: Argumento count de Buffer.BlockCopy deve ser número de bytes
dotnet_diagnostic.CA2018.severity = suggestion

# CA2019: Campos ThreadStatic não devem ter inicialização inline
dotnet_diagnostic.CA2019.severity = suggestion

# CA2020: Evite mudança comportamental com operadores built-in de IntPtr/UIntPtr (.NET 7)
dotnet_diagnostic.CA2020.severity = suggestion

# CA2021: Não chame Enumerable.Cast<T>/OfType<T> com tipos incompatíveis
dotnet_diagnostic.CA2021.severity = suggestion

# CA2022: Evite leitura inexata com Stream.Read (verifique o valor de retorno)
dotnet_diagnostic.CA2022.severity = suggestion

# CA2023: Chaves inválidas em template de mensagem de log
dotnet_diagnostic.CA2023.severity = suggestion

# CA2024: Não use StreamReader.EndOfStream em métodos async
dotnet_diagnostic.CA2024.severity = suggestion

# CA2025: Não passe instâncias IDisposable para tasks não aguardadas
dotnet_diagnostic.CA2025.severity = suggestion

# CA2026: Prefira JsonElement.Parse a JsonDocument.Parse().RootElement
dotnet_diagnostic.CA2026.severity = suggestion

# =============================================================================
# Quality Rules (CA) — Segurança
# =============================================================================

# CA2100: Revise queries SQL para vulnerabilidades de injeção
dotnet_diagnostic.CA2100.severity = suggestion

# CA2101: Especifique marshalling para argumentos string de P/Invoke
dotnet_diagnostic.CA2101.severity = suggestion

# CA2109: Revise handlers de eventos visíveis
dotnet_diagnostic.CA2109.severity = suggestion

# CA2119: Torne sealed (ou internal/não-virtual) métodos que implementam interfaces internas em tipos públicos herdáveis — risco de segurança: permite override externo de contrato interno
dotnet_diagnostic.CA2119.severity = suggestion

# CA2153: Evite capturar Corrupted State Exceptions
dotnet_diagnostic.CA2153.severity = suggestion

# =============================================================================
# Quality Rules (CA) — Uso
# =============================================================================

# CA2200: Relança para preservar detalhes da stack (use throw; não throw ex;)
dotnet_diagnostic.CA2200.severity = suggestion

# CA2201: Não lance tipos de exceção reservados (NullReferenceException etc.)
dotnet_diagnostic.CA2201.severity = suggestion

# CA2207: Inicialize campos estáticos de tipo de valor inline
dotnet_diagnostic.CA2207.severity = suggestion

# CA2208: Instancie ArgumentException corretamente (com paramName e message)
dotnet_diagnostic.CA2208.severity = suggestion

# CA2211: Campos não-constantes não devem ser visíveis (static mutable public)
dotnet_diagnostic.CA2211.severity = suggestion

# CA2213: Campos IDisposable devem ser descartados no Dispose
dotnet_diagnostic.CA2213.severity = suggestion

# CA2214: Não chame métodos virtuais em construtores
dotnet_diagnostic.CA2214.severity = suggestion

# CA2215: Métodos Dispose devem chamar base.Dispose()
dotnet_diagnostic.CA2215.severity = suggestion

# CA2216: Tipos IDisposable com recursos não-gerenciados devem declarar finalizador
dotnet_diagnostic.CA2216.severity = suggestion

# CA2217: Não marque enums com FlagsAttribute se os valores não forem potências de 2
dotnet_diagnostic.CA2217.severity = suggestion

# CA2218: Implemente GetHashCode ao sobrescrever Equals
dotnet_diagnostic.CA2218.severity = suggestion

# CA2219: Não lance exceções em cláusulas finally/fault/filter
dotnet_diagnostic.CA2219.severity = suggestion

# CA2224: Sobrescreva Equals ao sobrecarregar operator==
dotnet_diagnostic.CA2224.severity = suggestion

# CA2225: operator overloads devem ter alternativas nomeadas (op_Addition etc.)
dotnet_diagnostic.CA2225.severity = suggestion

# CA2226: Operadores devem ter symmetrical overloads (== e !=, < e >, etc.)
dotnet_diagnostic.CA2226.severity = suggestion

# CA2227: Propriedades de coleção devem ser somente leitura
dotnet_diagnostic.CA2227.severity = suggestion

# CA2229: Implemente construtores de serialização em tipos ISerializable
dotnet_diagnostic.CA2229.severity = suggestion

# CA2231: Sobrecarregue operator== ao sobrescrever ValueType.Equals
dotnet_diagnostic.CA2231.severity = suggestion

# CA2234: Passe objetos System.Uri em vez de strings em APIs que aceitam Uri
dotnet_diagnostic.CA2234.severity = suggestion

# CA2235: Marque todos os campos não-serializáveis em tipos serializáveis
dotnet_diagnostic.CA2235.severity = suggestion

# CA2237: Marque tipos ISerializable com SerializableAttribute
dotnet_diagnostic.CA2237.severity = suggestion

# CA2241: Forneça argumentos corretos para métodos de formatação (String.Format)
dotnet_diagnostic.CA2241.severity = suggestion

# CA2242: Teste NaN corretamente (use float.IsNaN, não == float.NaN)
dotnet_diagnostic.CA2242.severity = suggestion

# CA2243: Literais string em atributos devem ser válidos (URL, GUID, versão)
dotnet_diagnostic.CA2243.severity = suggestion

# CA2244: Não duplique inicializações de elemento indexado em object initializer
dotnet_diagnostic.CA2244.severity = suggestion

# CA2245: Não atribua uma propriedade a si mesma
dotnet_diagnostic.CA2245.severity = suggestion

# CA2246: Não atribua símbolo e seu membro na mesma instrução
dotnet_diagnostic.CA2246.severity = suggestion

# CA2247: Argumento de TaskCompletionSource deve ser TaskCreationOptions, não TaskContinuationOptions
dotnet_diagnostic.CA2247.severity = suggestion

# CA2248: Forneça argumento correto de enum para Enum.HasFlag
dotnet_diagnostic.CA2248.severity = suggestion

# CA2249: Considere usar String.Contains em vez de String.IndexOf para verificação de substring
dotnet_diagnostic.CA2249.severity = suggestion
