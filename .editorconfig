root = true

# =============================================================================
# .editorconfig — Regras completas para projetos C# .NET
# Referência: https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/
#             https://learn.microsoft.com/dotnet/fundamentals/code-analysis/quality-rules/
# =============================================================================

# Níveis de severidade dos analyzers (.editorconfig)
#
# none        → desativa a regra (não aparece, não aplica no format)
# silent      → invisível na IDE (só refactoring), não aplica no format
# suggestion  → sugestão leve na IDE, aplica com `dotnet format --severity info`
# warning     → aviso visível, aplica no `dotnet format` padrão
# error       → erro de build, sempre aplicado pelo format
#
# Dica:
# - use 'warning' para regras que quer aplicar automaticamente
# - use 'suggestion' para estilo opcional
# - use 'silent' para deixar disponível manualmente (sem interferência)
# - use 'none' para desativar completamente

# -----------------------------------------------------------------------------
# Configurações universais (todos os arquivos)
# -----------------------------------------------------------------------------
[*]
# Usa espaços para indentação (não tabs)
indent_style = space
# Garante que o arquivo termine com uma linha em branco
insert_final_newline = true
# Remove espaços em branco ao final das linhas
trim_trailing_whitespace = true
# Codificação padrão
charset = utf-8

# -----------------------------------------------------------------------------
# Arquivos XML / Projeto / Config
# -----------------------------------------------------------------------------
[*.xml]
indent_size = 2

[*.{csproj,fsproj,vbproj,proj,slnx}]
indent_size = 2

[*.{props,targets,config,nuspec}]
indent_size = 2

[*.json]
indent_size = 2

[*.{yml,yaml}]
indent_size = 2

# =============================================================================
# C# — Configurações principais
# =============================================================================
[*.cs]

#### Core EditorConfig Options ####

# Indentação de 4 espaços para C#
indent_size = 4
tab_width = 4

# =============================================================================
# .NET Coding Conventions (C# e VB)
# =============================================================================
[*.{cs,vb}]

# -----------------------------------------------------------------------------
# Organização de usings (IDE0055 / formatting)
# -----------------------------------------------------------------------------

# Separa grupos de using com linha em branco entre eles
# Sim:  using System;
#       [linha em branco]
#       using MyApp;
dotnet_separate_import_directive_groups = true

# Coloca diretivas System.* antes das demais
# Sim:  using System;
#       using System.Collections.Generic;
#       using MyLib;
dotnet_sort_system_directives_first = true

# IDE0073: Cabeçalho de arquivo (template). Use "unset" para desativar.
# Exemplo: file_header_template = Copyright (c) MyCompany. All rights reserved.
file_header_template = unset

# -----------------------------------------------------------------------------
# IDE0003 / IDE0009 — Qualificação com this. e Me.
# -----------------------------------------------------------------------------

# IDE0003 (false): Não use this. em eventos (this.MyEvent -> MyEvent)
# IDE0009 (true):  Use this. em eventos
dotnet_style_qualification_for_event = false:suggestion

# IDE0003 (false): Não use this. em campos (this._name -> _name)
dotnet_style_qualification_for_field = false:suggestion

# IDE0003 (false): Não use this. em métodos (this.Run() -> Run())
dotnet_style_qualification_for_method = false:suggestion

# IDE0003 (false): Não use this. em propriedades (this.Name -> Name)
dotnet_style_qualification_for_property = false:suggestion

# -----------------------------------------------------------------------------
# IDE0049 — Palavras-chave vs nomes de tipos BCL
# -----------------------------------------------------------------------------

# true: Use int em vez de Int32 para variáveis e parâmetros
# Sim: int x = 0;   Não: Int32 x = 0;
dotnet_style_predefined_type_for_locals_parameters_members = true:suggestion

# true: Use int.MaxValue em vez de Int32.MaxValue para acesso a membros
# Sim: int.MaxValue   Não: Int32.MaxValue
dotnet_style_predefined_type_for_member_access = true:suggestion

# -----------------------------------------------------------------------------
# IDE0047 / IDE0048 — Parênteses
# -----------------------------------------------------------------------------

# always_for_clarity: Mantém parênteses em operadores aritméticos para clareza
# Sim: var x = (a * b) + c;
dotnet_style_parentheses_in_arithmetic_binary_operators = always_for_clarity:suggestion

# always_for_clarity: Mantém parênteses em outros operadores binários (&&, ||, ??)
# Sim: var r = (a && b) || c;
dotnet_style_parentheses_in_other_binary_operators = always_for_clarity:suggestion

# never_if_unnecessary: Remove parênteses desnecessários em outros operadores
# Sim: var x = -a;   Não: var x = (-a);
dotnet_style_parentheses_in_other_operators = never_if_unnecessary:warning

# always_for_clarity: Mantém parênteses em operadores relacionais
# Sim: var r = (a < b) == (c > d);
dotnet_style_parentheses_in_relational_binary_operators = always_for_clarity:suggestion

# -----------------------------------------------------------------------------
# IDE0040 — Modificadores de acessibilidade
# -----------------------------------------------------------------------------

# for_non_interface_members: Exige modificador de acesso em todos os membros
# exceto membros de interface (que são public por padrão)
# Sim: public class Foo { private int _x; }
# Não: class Foo { int _x; }
dotnet_style_require_accessibility_modifiers = for_non_interface_members:warning

# -----------------------------------------------------------------------------
# Preferências de nível de expressão
# -----------------------------------------------------------------------------

# #DUVIDA, talvez warning
# IDE0029/IDE0030/IDE0270: Prefere ?? em vez de verificações de nulo ternárias
# Sim: var x = a ?? b;   Não: var x = a != null ? a : b;
dotnet_style_coalesce_expression = true:suggestion

# #DUVIDA, talvez warning
# IDE0028: Usa inicializadores de coleção
# Sim: var l = new List<int> { 1, 2, 3 };   Não: var l = new List<int>(); l.Add(1);
dotnet_style_collection_initializer = true:suggestion

# IDE0033: Usa nomes explícitos de tupla em vez de Item1/Item2
# Sim: tuple.Name   Não: tuple.Item1
dotnet_style_explicit_tuple_names = true:warning

# IDE0130: Namespace deve corresponder à estrutura de pastas
# Sim (em pasta Foo/Bar): namespace MyApp.Foo.Bar;
dotnet_style_namespace_match_folder = true:warning

# IDE0031: Prefere propagação de nulo (?.)
# Sim: var x = obj?.Property;   Não: var x = obj != null ? obj.Property : null;
dotnet_style_null_propagation = true:warning

# IDE0017: Usa inicializadores de objeto
# Sim: var p = new Person { Name = "Ana" };   Não: var p = new Person(); p.Name = "Ana";
dotnet_style_object_initializer = true:suggestion

# Posição do operador ao quebrar linha: no início da nova linha
# Sim:   var x = a
#            + b;
# end_of_line: Final da linha 
dotnet_style_operator_placement_when_wrapping = beginning_of_line

# IDE0032: Prefere propriedades automáticas
# Sim: public int Age { get; set; }
# Não: private int _age; public int Age { get { return _age; } set { _age = value; } }
dotnet_style_prefer_auto_properties = true:suggestion

# IDE0028/IDE0300-IDE0306: Prefere expressões de coleção []
# when_types_loosely_match: aplica quando os tipos são compatíveis
# Sim: int[] a = [1, 2, 3];   Não: int[] a = new int[] { 1, 2, 3 };
dotnet_style_prefer_collection_expression = when_types_loosely_match:suggestion

# IDE0054/IDE0074: Prefere atribuição composta
# Sim: x += 1;   Não: x = x + 1;
# IDE0074 cobre ??= especificamente
dotnet_style_prefer_compound_assignment = true:suggestion

# IDE0045: Prefere expressão condicional em atribuição
# Sim: var x = cond ? a : b;   Não: if (cond) x = a; else x = b;
dotnet_style_prefer_conditional_expression_over_assignment = true:suggestion

# IDE0046: Prefere expressão condicional em return
# Sim: return cond ? a : b;   Não: if (cond) return a; else return b;
dotnet_style_prefer_conditional_expression_over_return = true:suggestion

# IDE0220: Prefere cast explícito no foreach quando o tipo da fonte é fortemente tipado
# when_strongly_typed: aplica cast quando a coleção é fortemente tipada
dotnet_style_prefer_foreach_explicit_cast_in_source = when_strongly_typed:suggestion

# IDE0037: Prefere nomes inferidos em tipos anônimos
# Sim: new { Name }   Não: new { Name = Name }
dotnet_style_prefer_inferred_anonymous_type_member_names = true:suggestion

# IDE0037: Prefere nomes inferidos em tuplas
# Sim: (Name, Age)   Não: (Name: Name, Age: Age)
dotnet_style_prefer_inferred_tuple_names = true:suggestion

# IDE0041: Prefere verificação de nulo com is null em vez de ReferenceEquals
# Sim: obj is null   Não: object.ReferenceEquals(obj, null)
dotnet_style_prefer_is_null_check_over_reference_equality_method = true:suggestion

# IDE0075: Simplifica expressões booleanas condicionais
# Sim: return a && b;   Não: return a && b ? true : false;
dotnet_style_prefer_simplified_boolean_expressions = true:suggestion

# IDE0071: Simplifica interpolação de strings
# Sim: $"{x}"   Não: $"{x.ToString()}"
dotnet_style_prefer_simplified_interpolation = true:suggestion

# -----------------------------------------------------------------------------
# IDE0044 — Preferências de campo
# -----------------------------------------------------------------------------

# true: Adiciona readonly em campos que não são reatribuídos após o construtor
# Sim: private readonly int _x;
dotnet_style_readonly_field = true:warning

# -----------------------------------------------------------------------------
# IDE0060 — Preferências de parâmetro
# -----------------------------------------------------------------------------

# all: Reporta parâmetros não utilizados em todos os métodos (públicos e privados)
dotnet_code_quality_unused_parameters = all:suggestion

# -----------------------------------------------------------------------------
# IDE0079 — Supressões desnecessárias
# -----------------------------------------------------------------------------

# none: Não exclui nenhuma supressão desnecessária da análise
dotnet_remove_unnecessary_suppression_exclusions = none

# =============================================================================
# C# Coding Conventions
# =============================================================================
[*.cs]

# -----------------------------------------------------------------------------
# IDE0007 / IDE0008 — Preferências de var
# -----------------------------------------------------------------------------

# false: Use tipo explícito em vez de var para tipos primitivos
# Sim: int x = 0;   Não: var x = 0;
csharp_style_var_for_built_in_types = false:silent

# false: Use tipo explícito quando o tipo é aparente pela expressão
# Sim: Customer c = new Customer();   Não: var c = new Customer();
csharp_style_var_when_type_is_apparent = false:silent

# false: Use tipo explícito em demais casos
# Sim: IEnumerable<int> e = GetItems();   Não: var e = GetItems();
csharp_style_var_elsewhere = false:silent

# -----------------------------------------------------------------------------
# IDE0021-IDE0027 / IDE0053 / IDE0061 — Membros com corpo de expressão
# -----------------------------------------------------------------------------

# IDE0027 (true): Usa corpo de expressão em acessores de propriedade
# Sim: get => _name;   Não: get { return _name; }
csharp_style_expression_bodied_accessors = true:silent

# IDE0021 (false): Não usa corpo de expressão em construtores
# Sim: public Foo() { _x = 1; }   Não: public Foo() => _x = 1;
csharp_style_expression_bodied_constructors = false:silent

# IDE0026 (true): Usa corpo de expressão em indexadores
# Sim: public int this[int i] => _items[i];
csharp_style_expression_bodied_indexers = true:silent

# IDE0053 (true): Usa corpo de expressão em lambdas
# Sim: Func<int> f = () => 42;
csharp_style_expression_bodied_lambdas = true:suggestion

# IDE0061 (false): Não usa corpo de expressão em funções locais
# Sim: int Local() { return 1; }   Não: int Local() => 1;
csharp_style_expression_bodied_local_functions = false:silent

# IDE0022 (false): Não usa corpo de expressão em métodos
# Sim: void Run() { DoWork(); }   Não: void Run() => DoWork();
csharp_style_expression_bodied_methods = false:silent

# IDE0023/IDE0024 (false): Não usa corpo de expressão em operadores
# Sim: public static Foo operator +(Foo a, Foo b) { return new Foo(); }
csharp_style_expression_bodied_operators = false:silent

# IDE0025 (true): Usa corpo de expressão em propriedades simples
# Sim: public string Name => _name;
csharp_style_expression_bodied_properties = true:silent

# -----------------------------------------------------------------------------
# IDE0019 / IDE0020 / IDE0038 / IDE0078 / IDE0083 / IDE0150 — Pattern matching
# -----------------------------------------------------------------------------

# IDE0019 (true): Usa pattern matching em vez de as + null check
# Sim: if (obj is string s) { }   Não: var s = obj as string; if (s != null) { }
csharp_style_pattern_matching_over_as_with_null_check = true:suggestion

# IDE0020/IDE0038 (true): Usa pattern matching em vez de is + cast
# Sim: if (obj is int i) { }   Não: if (obj is int) { var i = (int)obj; }
csharp_style_pattern_matching_over_is_with_cast_check = true:suggestion

# IDE0170 (true): Simplifica padrão de propriedade estendido
# Sim: if (a is { B.C: 1 }) { }   Não: if (a is { B: { C: 1 } }) { }
csharp_style_prefer_extended_property_pattern = true:suggestion

# IDE0083 (true): Usa o operador not em patterns
# Sim: if (obj is not null) { }   Não: if (!(obj is null)) { }
csharp_style_prefer_not_pattern = true:suggestion

# IDE0078 (true): Prefere pattern matching quando possível
# Sim: if (obj is int or string) { }
csharp_style_prefer_pattern_matching = true:silent

# IDE0066 (true): Prefere switch expression em vez de switch statement
# Sim: var x = y switch { 1 => "a", _ => "b" };
csharp_style_prefer_switch_expression = true:suggestion

# IDE0150 (true): Prefere null check a verificação de tipo
# Sim: if (obj is null) { }   Não: if (obj is not MyType) { }  (quando só verifica nulo)
csharp_style_prefer_null_check_over_type_check = true:suggestion

# -----------------------------------------------------------------------------
# IDE1005 — Null-checking em delegates
# -----------------------------------------------------------------------------

# true: Usa chamada de delegate condicional (?.)
# Sim: handler?.Invoke(this, args);   Não: if (handler != null) handler(this, args);
csharp_style_conditional_delegate_call = true:suggestion

# -----------------------------------------------------------------------------
# Modificadores
# -----------------------------------------------------------------------------

# IDE0320 (true): Prefere funções anônimas static quando não capturam estado
# Sim: Action f = static () => Console.WriteLine("hello");
csharp_prefer_static_anonymous_function = true:suggestion

# IDE0062 (true): Prefere funções locais static quando não capturam estado
# Sim: static void Local() { }
csharp_prefer_static_local_function = true:warning

# IDE0036: Ordem preferida dos modificadores
# public > private > protected > internal > ... > async
csharp_preferred_modifier_order = public,private,protected,internal,file,const,static,extern,new,virtual,abstract,sealed,override,readonly,unsafe,required,volatile,async:suggestion

# IDE0250 (true): Structs podem ser marcadas como readonly quando possível
# Sim: readonly struct Point { public int X { get; init; } }
csharp_style_prefer_readonly_struct = true:suggestion

# IDE0251 (true): Membros de struct podem ser readonly quando não modificam estado
# Sim: public readonly int GetX() => X;
csharp_style_prefer_readonly_struct_member = true:suggestion

# -----------------------------------------------------------------------------
# Preferências de bloco de código
# -----------------------------------------------------------------------------

# IDE0011 (true): Exige chaves em blocos de controle
# Sim: if (x) { DoIt(); }   Não: if (x) DoIt();
csharp_prefer_braces = true:none

# IDE0063 (true): Usa declaração using simples (sem bloco)
# Sim: using var fs = File.Open(...);   Não: using (var fs = File.Open(...)) { }
csharp_prefer_simple_using_statement = true:suggestion

# IDE0160/IDE0161: Estilo de declaração de namespace
# file_scoped: namespace MyApp.Services;  (sem chaves — C# 10+)
# block_scoped: namespace MyApp.Services { ... }
csharp_style_namespace_declarations = file_scoped:warning

# IDE0200 (true): Remove lambda desnecessária — usa method group
# Sim: list.ForEach(Console.WriteLine);   Não: list.ForEach(x => Console.WriteLine(x));
csharp_style_prefer_method_group_conversion = true:silent

# IDE0290 (true): Prefere construtores primários (C# 12+)
# Sim: class Point(int x, int y);
csharp_style_prefer_primary_constructors = true:suggestion

# IDE0210/IDE0211: Prefere top-level statements (C# 9+)
# true = prefere top-level (sem class Program/Main explícitos)
csharp_style_prefer_top_level_statements = true:silent

# -----------------------------------------------------------------------------
# Preferências de nível de expressão (C#)
# -----------------------------------------------------------------------------

# IDE0034 (true): Simplifica expressão default
# Sim: default   Não: default(int)
csharp_prefer_simple_default_expression = true:suggestion

# IDE0042 (true): Deconstrói declaração de variável
# Sim: var (x, y) = GetPoint();   Não: var p = GetPoint(); var x = p.X;
csharp_style_deconstructed_variable_declaration = true:suggestion

# IDE0090 (true): Cria objeto implicitamente quando o tipo é aparente (new())
# Sim: Customer c = new();   Não: Customer c = new Customer();
csharp_style_implicit_object_creation_when_type_is_apparent = true:suggestion

# IDE0018 (true): Declara variável inline em out
# Sim: int.TryParse(s, out int n)   Não: int n; int.TryParse(s, out n);
csharp_style_inlined_variable_declaration = true:suggestion

# IDE0056 (true): Usa operador de índice ^
# Sim: var last = list[^1];   Não: var last = list[list.Count - 1];
csharp_style_prefer_index_operator = true:suggestion

# IDE0039 (true): Prefere função local a função anônima
# Sim: int Local() => 1;  em vez de  Func<int> f = () => 1;
csharp_style_prefer_local_over_anonymous_function = true:suggestion

# IDE0057 (true): Usa operador de intervalo ..
# Sim: var sub = arr[1..4];   Não: var sub = arr.Skip(1).Take(3);
csharp_style_prefer_range_operator = true:suggestion

# IDE0180 (true): Usa tupla para troca de valores
# Sim: (a, b) = (b, a);   Não: var tmp = a; a = b; b = tmp;
csharp_style_prefer_tuple_swap = true:suggestion

# IDE0230 (true): Prefere literal de string UTF-8
# Sim: ReadOnlySpan<byte> b = "hello"u8;
csharp_style_prefer_utf8_string_literals = true:suggestion

# IDE0016 (true): Usa throw expression em vez de bloco if throw
# Sim: _name = name ?? throw new ArgumentNullException(nameof(name));
csharp_style_throw_expression = true:suggestion

# IDE0059: Prefere descartar variável não utilizada com _
# Sim: _ = GetValue();   Não: var unused = GetValue();
csharp_style_unused_value_assignment_preference = discard_variable:suggestion

# IDE0058: Prefere descartar resultado de expressão não utilizado com _
# Sim: _ = list.Remove(item);
csharp_style_unused_value_expression_statement_preference = discard_variable:silent

# IDE0330 (true): Prefere System.Threading.Lock em vez de object para locks (C# 13+)
# Sim: private readonly Lock _lock = new();   Não: private readonly object _lock = new();
csharp_prefer_system_threading_lock = true:suggestion

# IDE0340 (true): Prefere tipo genérico não vinculado em nameof
# Sim: nameof(List<>)   Não: nameof(List<int>)
csharp_style_prefer_unbound_generic_type_in_nameof = true:suggestion

# IDE0350 (true): Prefere lambda implicitamente tipada quando o tipo pode ser inferido
# Sim: var f = (int x) => x + 1;
csharp_style_prefer_implicitly_typed_lambda_expression = true:suggestion

# IDE0360 (true): Simplifica acessores de propriedade
# Sim: get => _value;   Não: get { return _value; }
csharp_style_prefer_simple_property_accessors = true:suggestion

# -----------------------------------------------------------------------------
# IDE0065 — Posicionamento de diretiva using
# -----------------------------------------------------------------------------

# outside_namespace: Coloca using fora do namespace
# Sim: using System; namespace Foo { }
# inside_namespace: Coloca using dentro do namespace
csharp_using_directive_placement = outside_namespace:silent

# =============================================================================
# C# Formatting Rules (IDE0055)
# =============================================================================

# -----------------------------------------------------------------------------
# Preferências de nova linha
# -----------------------------------------------------------------------------

# true: catch em nova linha
# try { } [NOVA LINHA] catch { }
csharp_new_line_before_catch = true

# true: else em nova linha
# if (...) { } [NOVA LINHA] else { }
csharp_new_line_before_else = true

# true: finally em nova linha
# catch { } [NOVA LINHA] finally { }
csharp_new_line_before_finally = true

# true: Membros de tipos anônimos em linhas separadas
# var z = new { [NOVA LINHA] A = 1, [NOVA LINHA] B = 2 }
csharp_new_line_before_members_in_anonymous_types = true

# true: Membros de inicializadores de objeto em linhas separadas
# var p = new Person { [NOVA LINHA] Name = "Ana", [NOVA LINHA] Age = 30 }
csharp_new_line_before_members_in_object_initializers = true

# all: Abre chave { em nova linha para todos os elementos (estilo Allman)
# Sim: void Foo() [NOVA LINHA] { }    Não: void Foo() {
csharp_new_line_before_open_brace = all

# true: Cláusulas de query expression em linhas separadas
# var q = from a in e [NOVA LINHA] where a > 0 [NOVA LINHA] select a;
csharp_new_line_between_query_expression_clauses = true

# -----------------------------------------------------------------------------
# Preferências de indentação
# -----------------------------------------------------------------------------

# true: Indenta o conteúdo de blocos
# { [INDENTADO] Console.WriteLine(); }
csharp_indent_block_contents = true

# false: Não indenta as chaves em si
# void Foo() [SEM INDENT] {
csharp_indent_braces = false

# true: Indenta o conteúdo de case no switch
# switch(x) { case 1: [INDENTADO] break; }
csharp_indent_case_contents = true

# true: Indenta o bloco dentro de case como bloco separado
# case 0: [NOVA LINHA] { [INDENTADO] break; }
csharp_indent_case_contents_when_block = true

# one_less_than_current: Labels (goto) ficam um nível abaixo do contexto atual
# flush_left: na coluna 0 | no_change: mesmo nível
csharp_indent_labels = one_less_than_current

# true: Indenta os labels de case no switch
# switch(x) { [INDENTADO] case 1: }
csharp_indent_switch_labels = true

# -----------------------------------------------------------------------------
# Preferências de espaçamento
# -----------------------------------------------------------------------------

# false: Sem espaço após cast
# Sim: (int)x   Não: (int) x
csharp_space_after_cast = false

# true: Espaço após : na cláusula de herança
# Sim: class Foo : IBar { }   (espaço após :)
csharp_space_after_colon_in_inheritance_clause = true

# true: Espaço após vírgula
# Sim: Foo(a, b, c)   Não: Foo(a,b,c)
csharp_space_after_comma = true

# false: Sem espaço após ponto
# Sim: obj.Method()   Não: obj. Method()
csharp_space_after_dot = false

# true: Espaço após palavra-chave de controle de fluxo
# Sim: if (x)   Não: if(x)
csharp_space_after_keywords_in_control_flow_statements = true

# true: Espaço após ; no for
# Sim: for (int i = 0; i < 10; i++)
csharp_space_after_semicolon_in_for_statement = true

# before_and_after: Espaços ao redor de operadores binários
# Sim: var x = a + b;   Não: var x = a+b;
csharp_space_around_binary_operators = before_and_after

# false: Sem espaço em volta de declarações
csharp_space_around_declaration_statements = false

# true: Espaço antes de : na cláusula de herança
# Sim: class Foo : IBar { }   (espaço antes de :)
csharp_space_before_colon_in_inheritance_clause = true

# false: Sem espaço antes de vírgula
# Sim: Foo(a, b)   Não: Foo(a , b)
csharp_space_before_comma = false

# false: Sem espaço antes de ponto
# Sim: obj.Method()   Não: obj .Method()
csharp_space_before_dot = false

# false: Sem espaço antes de colchete de abertura
# Sim: arr[0]   Não: arr [0]
csharp_space_before_open_square_brackets = false

# false: Sem espaço antes de ; no for
# Sim: for (int i = 0; i < 10; i++)
csharp_space_before_semicolon_in_for_statement = false

# false: Sem espaço entre colchetes vazios
# Sim: int[]   Não: int[ ]
csharp_space_between_empty_square_brackets = false

# false: Sem espaço em lista de parâmetros vazia na chamada
# Sim: Foo()   Não: Foo( )
csharp_space_between_method_call_empty_parameter_list_parentheses = false

# false: Sem espaço entre nome do método e ( na chamada
# Sim: Foo()   Não: Foo ()
csharp_space_between_method_call_name_and_opening_parenthesis = false

# false: Sem espaço dentro dos parênteses na chamada
# Sim: Foo(a, b)   Não: Foo( a, b )
csharp_space_between_method_call_parameter_list_parentheses = false

# false: Sem espaço em lista de parâmetros vazia na declaração
# Sim: void Foo()   Não: void Foo( )
csharp_space_between_method_declaration_empty_parameter_list_parentheses = false

# false: Sem espaço entre nome do método e ( na declaração
# Sim: void Foo(int x)   Não: void Foo (int x)
csharp_space_between_method_declaration_name_and_open_parenthesis = false

# false: Sem espaço dentro dos parênteses na declaração
# Sim: void Foo(int x)   Não: void Foo( int x )
csharp_space_between_method_declaration_parameter_list_parentheses = false

# false: Sem espaço dentro de parênteses genéricos
# Sim: (a + b)   Não: ( a + b )
csharp_space_between_parentheses = false

# false: Sem espaço entre colchetes em array não vazio
# Sim: arr[0]   Não: arr[ 0 ]
csharp_space_between_square_brackets = false

# -----------------------------------------------------------------------------
# Preferências de quebra de linha (wrapping)
# -----------------------------------------------------------------------------

# true: Mantém blocos de uma única instrução em uma linha
# Sim: public int X { get; set; }
csharp_preserve_single_line_blocks = true

# true: Mantém declarações simples em uma linha
# Sim: if (x) return;
csharp_preserve_single_line_statements = true

# =============================================================================
# Whitespace experimental (IDE2000–IDE2006)
# =============================================================================

# IDE2000: Evita múltiplas linhas em branco consecutivas
# true = permite; false = não permite
dotnet_style_allow_multiple_blank_lines_experimental = false:silent

# IDE2001: Declarações embutidas devem estar em linhas próprias
# false = não permite if (x) return; (exige nova linha)
csharp_style_allow_embedded_statements_on_same_line_experimental = false:silent

# IDE2002: Não permite linha em branco entre chaves consecutivas
# false = não permite linha em branco entre { e }
csharp_style_allow_blank_lines_between_consecutive_braces_experimental = false:silent

# IDE2003: Exige linha em branco entre bloco e próxima declaração
# true = permite instrução imediatamente após bloco
dotnet_style_allow_statement_immediately_after_block_experimental = false:silent

# IDE2004: Não permite linha em branco após : de inicializador de construtor
# false = não permite linha em branco após base(...):\n[linha]\n{
csharp_style_allow_blank_line_after_colon_in_constructor_initializer_experimental = false:silent

# IDE2005: Não permite linha em branco após token de expressão condicional
# false = cond\n[linha]\n? a : b não é permitido
csharp_style_allow_blank_line_after_token_in_conditional_expression_experimental = false:silent

# IDE2006: Não permite linha em branco após token de expressão lambda =>
# false = () =>\n[linha]\n{ } não é permitido
csharp_style_allow_blank_line_after_token_in_arrow_expression_clause_experimental = false:silent

# =============================================================================
# Naming styles (IDE1006)
# =============================================================================
[*.{cs,vb}]

# -----------------------------------------------------------------------------
# Regras de nomenclatura
# Cada regra tem: severity, symbols (o que se aplica), style (como nomear)
# -----------------------------------------------------------------------------

# Tipos e namespaces → PascalCase
# Sim: class MyService { }   namespace MyApp.Services { }
dotnet_naming_rule.types_and_namespaces_should_be_pascalcase.severity = suggestion
dotnet_naming_rule.types_and_namespaces_should_be_pascalcase.symbols = types_and_namespaces
dotnet_naming_rule.types_and_namespaces_should_be_pascalcase.style = pascalcase

# Interfaces → IPascalCase (prefixo I)
# Sim: interface IRepository { }
dotnet_naming_rule.interfaces_should_be_ipascalcase.severity = suggestion
dotnet_naming_rule.interfaces_should_be_ipascalcase.symbols = interfaces
dotnet_naming_rule.interfaces_should_be_ipascalcase.style = ipascalcase

# Parâmetros de tipo genérico → TPascalCase (prefixo T)
# Sim: class Container<TItem> { }
dotnet_naming_rule.type_parameters_should_be_tpascalcase.severity = suggestion
dotnet_naming_rule.type_parameters_should_be_tpascalcase.symbols = type_parameters
dotnet_naming_rule.type_parameters_should_be_tpascalcase.style = tpascalcase

# Métodos → PascalCase
# Sim: public void ProcessOrder() { }
dotnet_naming_rule.methods_should_be_pascalcase.severity = suggestion
dotnet_naming_rule.methods_should_be_pascalcase.symbols = methods
dotnet_naming_rule.methods_should_be_pascalcase.style = pascalcase

# Propriedades → PascalCase
# Sim: public string FullName { get; set; }
dotnet_naming_rule.properties_should_be_pascalcase.severity = suggestion
dotnet_naming_rule.properties_should_be_pascalcase.symbols = properties
dotnet_naming_rule.properties_should_be_pascalcase.style = pascalcase

# Eventos → PascalCase
# Sim: public event EventHandler OrderPlaced;
dotnet_naming_rule.events_should_be_pascalcase.severity = suggestion
dotnet_naming_rule.events_should_be_pascalcase.symbols = events
dotnet_naming_rule.events_should_be_pascalcase.style = pascalcase

# Variáveis locais → camelCase
# Sim: int orderCount = 0;
dotnet_naming_rule.local_variables_should_be_camelcase.severity = suggestion
dotnet_naming_rule.local_variables_should_be_camelcase.symbols = local_variables
dotnet_naming_rule.local_variables_should_be_camelcase.style = camelcase

# Constantes locais → camelCase
# Sim: const int maxRetries = 3;
dotnet_naming_rule.local_constants_should_be_camelcase.severity = suggestion
dotnet_naming_rule.local_constants_should_be_camelcase.symbols = local_constants
dotnet_naming_rule.local_constants_should_be_camelcase.style = camelcase

# Parâmetros → camelCase
# Sim: void Process(string orderName) { }
dotnet_naming_rule.parameters_should_be_camelcase.severity = suggestion
dotnet_naming_rule.parameters_should_be_camelcase.symbols = parameters
dotnet_naming_rule.parameters_should_be_camelcase.style = camelcase

# Campos públicos/internos → PascalCase
# Sim: public int MaxItems;
dotnet_naming_rule.public_fields_should_be_pascalcase.severity = suggestion
dotnet_naming_rule.public_fields_should_be_pascalcase.symbols = public_fields
dotnet_naming_rule.public_fields_should_be_pascalcase.style = pascalcase

# Campos privados/protegidos → _camelCase
# Sim: private string _customerName;
dotnet_naming_rule.private_fields_should_be__camelcase.severity = suggestion
dotnet_naming_rule.private_fields_should_be__camelcase.symbols = private_fields
dotnet_naming_rule.private_fields_should_be__camelcase.style = _camelcase

# Campos privados estáticos → s_camelCase
# Sim: private static int s_instanceCount;
dotnet_naming_rule.private_static_fields_should_be_s_camelcase.severity = suggestion
dotnet_naming_rule.private_static_fields_should_be_s_camelcase.symbols = private_static_fields
dotnet_naming_rule.private_static_fields_should_be_s_camelcase.style = s_camelcase

# Constantes públicas/internas → PascalCase
# Sim: public const int MaxRetries = 5;
dotnet_naming_rule.public_constant_fields_should_be_pascalcase.severity = suggestion
dotnet_naming_rule.public_constant_fields_should_be_pascalcase.symbols = public_constant_fields
dotnet_naming_rule.public_constant_fields_should_be_pascalcase.style = pascalcase

# Constantes privadas/protegidas → PascalCase
# Sim: private const int BufferSize = 1024;
dotnet_naming_rule.private_constant_fields_should_be_pascalcase.severity = suggestion
dotnet_naming_rule.private_constant_fields_should_be_pascalcase.symbols = private_constant_fields
dotnet_naming_rule.private_constant_fields_should_be_pascalcase.style = pascalcase

# Campos static readonly públicos/internos → PascalCase
# Sim: public static readonly TimeSpan DefaultTimeout = TimeSpan.FromSeconds(30);
dotnet_naming_rule.public_static_readonly_fields_should_be_pascalcase.severity = suggestion
dotnet_naming_rule.public_static_readonly_fields_should_be_pascalcase.symbols = public_static_readonly_fields
dotnet_naming_rule.public_static_readonly_fields_should_be_pascalcase.style = pascalcase

# Campos static readonly privados/protegidos → PascalCase
# Sim: private static readonly Regex EmailRegex = new(...);
dotnet_naming_rule.private_static_readonly_fields_should_be_pascalcase.severity = suggestion
dotnet_naming_rule.private_static_readonly_fields_should_be_pascalcase.symbols = private_static_readonly_fields
dotnet_naming_rule.private_static_readonly_fields_should_be_pascalcase.style = pascalcase

# Enums → PascalCase
# Sim: enum OrderStatus { Pending, Shipped }
dotnet_naming_rule.enums_should_be_pascalcase.severity = suggestion
dotnet_naming_rule.enums_should_be_pascalcase.symbols = enums
dotnet_naming_rule.enums_should_be_pascalcase.style = pascalcase

# Funções locais → PascalCase
# Sim: void ProcessOrder() { void ValidateInput() { } }
dotnet_naming_rule.local_functions_should_be_pascalcase.severity = suggestion
dotnet_naming_rule.local_functions_should_be_pascalcase.symbols = local_functions
dotnet_naming_rule.local_functions_should_be_pascalcase.style = pascalcase

# Membros não-campo (propriedades, eventos, métodos) → PascalCase
dotnet_naming_rule.non_field_members_should_be_pascalcase.severity = suggestion
dotnet_naming_rule.non_field_members_should_be_pascalcase.symbols = non_field_members
dotnet_naming_rule.non_field_members_should_be_pascalcase.style = pascalcase

